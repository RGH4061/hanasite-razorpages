        <ul style="list-style:none;padding:0;margin:0 0 16px;"><li style="display:grid;grid-template-columns:16px 1fr;gap:8px;align-items:baseline;padding:6px 0;"><span style="color:var(--hana-blue);font-weight:700;">&rsaquo;</span><span style="font-family:var(--font-text);font-size:13px;color:var(--ink-2);line-height:1.5;">SMT on flex circuit</span></li><li style="display:grid;grid-template-columns:16px 1fr;gap:8px;align-items:baseline;padding:6px 0;"><span style="color:var(--hana-blue);font-weight:700;">&rsaquo;</span><span style="font-family:var(--font-text);font-size:13px;color:var(--ink-2);line-height:1.5;">Wire bond on flexible circuit</span></li><li style="display:grid;grid-template-columns:16px 1fr;gap:8px;align-items:baseline;padding:6px 0;"><span style="color:var(--hana-blue);font-weight:700;">&rsaquo;</span><span style="font-family:var(--font-text);font-size:13px;color:var(--ink-2);line-height:1.5;">BGA on flex with underfill</span></li><li style="display:grid;grid-template-columns:16px 1fr;gap:8px;align-items:baseline;padding:6px 0;"><span style="color:var(--hana-blue);font-weight:700;">&rsaquo;</span><span style="font-family:var(--font-text);font-size:13px;color:var(--ink-2);line-height:1.5;">Die attach &amp; glob-top on flex</span></li></ul>
