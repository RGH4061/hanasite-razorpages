    <div class="hana-spec-block" style="margin-top:18px;"><div class="hana-spec-item"><div class="hana-spec-label" style="display:block;margin-bottom:8px;">Direct on flex</div><div class="hana-spec-value" style="font-family:var(--font-mono);font-size:17px;">SMT + WB</div></div><div class="hana-spec-item"><div class="hana-spec-label" style="display:block;margin-bottom:8px;">On flex, underfilled</div><div class="hana-spec-value" style="font-family:var(--font-mono);font-size:22px;">BGA</div></div><div class="hana-spec-item"><div class="hana-spec-label" style="display:block;margin-bottom:8px;">Fine-pitch bond</div><div class="hana-spec-value" style="font-family:var(--font-mono);font-size:17px;">ACF · hot-bar</div></div><div class="hana-spec-item"><div class="hana-spec-label" style="display:block;margin-bottom:8px;">& flex-to-ceramic</div><div class="hana-spec-value" style="font-family:var(--font-mono);font-size:17px;">Flex ↔ PCB</div></div></div>
  </div></div></div>

