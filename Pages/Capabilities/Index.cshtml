@page
@{
    ViewData["Title"] = "Capabilities — EMS, OSAT & microelectronics";
    ViewData["Description"] = "Board assembly, semiconductor packaging and test, microelectronic assembly, RFID, automation and engineering partnership — under one group.";
}

@* Capabilities overview. Links to the six parent-capability hubs. *@

<style>
  .cap-ov-card{ transition:border-color 170ms ease, box-shadow 170ms ease, transform 170ms ease; }
  .cap-ov-card:hover{ border-color:color-mix(in srgb, var(--hana-blue) 60%, var(--line)) !important; box-shadow:0 8px 22px rgba(18,131,221,.12); transform:translateY(-2px); }
  .cap-ov-card:hover .cap-ov-go{ gap:10px; }
</style>

<div style="border-bottom:1px solid var(--line);background:var(--bg);">
  <div style="max-width:1240px;margin:0 auto;padding:11px 32px;font-size:12.5px;color:var(--ink-3);display:flex;gap:8px;align-items:center;">
    <a href="/" class="hana-link" style="font-size:12.5px;">Home</a>
    <span style="color:var(--line);">&rsaquo;</span>
    <span style="color:var(--ink);font-weight:600;">Capabilities</span>
  </div>
</div>

<div style="max-width:1000px;margin:0 auto;padding:62px 32px 16px;">
  <div style="font-family:var(--font-text);font-size:10px;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;color:var(--hana-blue);margin-bottom:14px;">Capabilities</div>
  <h1 style="font-family:var(--font-display);font-size:50px;font-weight:700;color:var(--ink);line-height:1.04;letter-spacing:-0.03em;margin:0 0 20px;max-width:820px;text-wrap:balance;">EMS and OSAT under one roof</h1>
  <p style="font-family:var(--font-text);font-size:18.5px;color:var(--ink-2);line-height:1.55;max-width:680px;margin:0;text-wrap:pretty;">From a fine-pitch surface-mount line through die-level packaging and test to the finished, tested unit &mdash; the same qualified processes run across our plants in China, Thailand, Cambodia and the USA.</p>
</div>

<div style="max-width:1000px;margin:0 auto;padding:36px 32px 80px;">
  <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:18px;">
      <a href="/capabilities/pcba-box-build" class="cap-ov-card" style="text-decoration:none;border:1px solid var(--line);border-radius:var(--radius-card);background:#fff;padding:28px 26px;display:flex;flex-direction:column;">
      <div style="font-family:var(--font-text);font-size:10px;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:var(--hana-blue);margin-bottom:12px;">3 processes</div>
      <div style="font-family:var(--font-display);font-size:22px;font-weight:600;color:var(--ink);letter-spacing:-0.01em;margin-bottom:10px;line-height:1.2;">PCBA &amp; Box Build</div>
      <p style="font-family:var(--font-text);font-size:14px;color:var(--ink-2);line-height:1.6;margin:0 0 18px;">Board assembly and full product assembly under one group — from a fine-pitch surface-mount line through bare-die work to the finished, tested unit.</p>
      <span class="cap-ov-go" style="margin-top:auto;display:inline-flex;align-items:center;gap:6px;font-size:11px;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;color:var(--hana-blue);">Explore <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="var(--hana-blue)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg></span>
    </a>
      <a href="/capabilities/osat" class="cap-ov-card" style="text-decoration:none;border:1px solid var(--line);border-radius:var(--radius-card);background:#fff;padding:28px 26px;display:flex;flex-direction:column;">
      <div style="font-family:var(--font-text);font-size:10px;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:var(--hana-blue);margin-bottom:12px;">6 processes</div>
      <div style="font-family:var(--font-display);font-size:22px;font-weight:600;color:var(--ink);letter-spacing:-0.01em;margin-bottom:10px;line-height:1.2;">OSAT</div>
      <p style="font-family:var(--font-text);font-size:14px;color:var(--ink-2);line-height:1.6;margin:0 0 18px;">Packaging and test at the die level — wafer processing, die attach, wire bond, flip chip and final test under one roof.</p>
      <span class="cap-ov-go" style="margin-top:auto;display:inline-flex;align-items:center;gap:6px;font-size:11px;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;color:var(--hana-blue);">Explore <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="var(--hana-blue)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg></span>
    </a>
      <a href="/capabilities/microelectronic-assembly" class="cap-ov-card" style="text-decoration:none;border:1px solid var(--line);border-radius:var(--radius-card);background:#fff;padding:28px 26px;display:flex;flex-direction:column;">
      <div style="font-family:var(--font-text);font-size:10px;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:var(--hana-blue);margin-bottom:12px;">4 processes</div>
      <div style="font-family:var(--font-display);font-size:22px;font-weight:600;color:var(--ink);letter-spacing:-0.01em;margin-bottom:10px;line-height:1.2;">Microelectronic Assembly</div>
      <p style="font-family:var(--font-text);font-size:14px;color:var(--ink-2);line-height:1.6;margin:0 0 18px;">The precision end of the group — flip chip, MEMS and sensor assembly, fine interconnect and micro-assembly, where placement is measured in microns.</p>
      <span class="cap-ov-go" style="margin-top:auto;display:inline-flex;align-items:center;gap:6px;font-size:11px;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;color:var(--hana-blue);">Explore <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="var(--hana-blue)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg></span>
    </a>
      <a href="/capabilities/rfid-smart-tags" class="cap-ov-card" style="text-decoration:none;border:1px solid var(--line);border-radius:var(--radius-card);background:#fff;padding:28px 26px;display:flex;flex-direction:column;">
      <div style="font-family:var(--font-text);font-size:10px;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:var(--hana-blue);margin-bottom:12px;">2 processes</div>
      <div style="font-family:var(--font-display);font-size:22px;font-weight:600;color:var(--ink);letter-spacing:-0.01em;margin-bottom:10px;line-height:1.2;">RFID &amp; Smart Tags</div>
      <p style="font-family:var(--font-text);font-size:14px;color:var(--ink-2);line-height:1.6;margin:0 0 18px;">High-volume RFID inlays and ruggedized tags — coil and antenna assembly, chip attach and lamination, built for environments that destroy ordinary labels.</p>
      <span class="cap-ov-go" style="margin-top:auto;display:inline-flex;align-items:center;gap:6px;font-size:11px;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;color:var(--hana-blue);">Explore <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="var(--hana-blue)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg></span>
    </a>
      <a href="/capabilities/automation" class="cap-ov-card" style="text-decoration:none;border:1px solid var(--line);border-radius:var(--radius-card);background:#fff;padding:28px 26px;display:flex;flex-direction:column;">
      <div style="font-family:var(--font-text);font-size:10px;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:var(--hana-blue);margin-bottom:12px;">3 processes</div>
      <div style="font-family:var(--font-display);font-size:22px;font-weight:600;color:var(--ink);letter-spacing:-0.01em;margin-bottom:10px;line-height:1.2;">Automation</div>
      <p style="font-family:var(--font-text);font-size:14px;color:var(--ink-2);line-height:1.6;margin:0 0 18px;">The inspection, handling and data layer that runs underneath every line — in-line optical inspection, robotic handling and unit-level traceability.</p>
      <span class="cap-ov-go" style="margin-top:auto;display:inline-flex;align-items:center;gap:6px;font-size:11px;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;color:var(--hana-blue);">Explore <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="var(--hana-blue)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg></span>
    </a>
      <a href="/capabilities/dfx-jdm" class="cap-ov-card" style="text-decoration:none;border:1px solid var(--line);border-radius:var(--radius-card);background:#fff;padding:28px 26px;display:flex;flex-direction:column;">
      <div style="font-family:var(--font-text);font-size:10px;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:var(--hana-blue);margin-bottom:12px;">3 processes</div>
      <div style="font-family:var(--font-display);font-size:22px;font-weight:600;color:var(--ink);letter-spacing:-0.01em;margin-bottom:10px;line-height:1.2;">DFx &amp; JDM Collaboration</div>
      <p style="font-family:var(--font-text);font-size:14px;color:var(--ink-2);line-height:1.6;margin:0 0 18px;">How we work with your engineering team before volume — design-for-excellence review, joint development and new product introduction.</p>
      <span class="cap-ov-go" style="margin-top:auto;display:inline-flex;align-items:center;gap:6px;font-size:11px;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;color:var(--hana-blue);">Explore <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="var(--hana-blue)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg></span>
    </a>
  </div>
</div>

<section data-hana-bg="halftone" data-variant="dark" data-accent="" data-fade="none" style="background:var(--hana-blue-deep);color:#fff;position:relative;overflow:hidden;">
  <div style="max-width:1080px;margin:0 auto;padding:72px 32px;text-align:center;position:relative;z-index:1;">
    <h2 class="hana-h2" style="color:#fff;margin:0 auto 16px;max-width:640px;">Tell us what you&rsquo;re building</h2>
    <p style="font-size:17px;line-height:1.6;color:rgba(255,255,255,0.8);max-width:560px;margin:0 auto 32px;">Send a BOM or a design file and our engineering team will point you to the right process.</p>
    <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;">
      <a href="/contact/rfq" class="hana-btn hana-btn-on-dark">Request a quote</a>
    </div>
  </div>
</section>
