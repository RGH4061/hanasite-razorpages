@page
@{
    ViewData["Title"] = "Capabilities — EMS, OSAT & microelectronics";
    ViewData["Description"] = "Board assembly, semiconductor packaging and test, microelectronic assembly, RFID, automation and engineering partnership — under one group.";
}

@* Capabilities overview — radial diagram of the six parent-capability hubs.
   Nodes are positioned in a circle by the inline script; the globe background
   and node geometry re-render on resize. *@

<style>
  .radial-section {
    background: var(--bg);
    padding: 0 0 72px;
    overflow: hidden;
    position: relative;
  }
  .radial-hero {
    max-width: 1080px; margin: 0 auto;
    padding: 72px 40px 32px;
    position: relative; z-index: 1;
  }
  .radial-eyebrow {
    font-family: var(--font-mono);
    font-size: 10px; font-weight: 500; letter-spacing: .12em; text-transform: uppercase;
    color: #7EC8FF; margin-bottom: 18px;
    display: flex; align-items: center; gap: 10px;
  }
  .radial-eyebrow::before {
    content: ''; display: inline-block;
    width: 24px; height: 1px;
    background: #7EC8FF; opacity: 0.6;
  }
  .radial-hero h1 {
    font-family: var(--font-display); font-weight: 700; font-size: 56px;
    line-height: 1.02; letter-spacing: -.032em; color: #fff;
    margin: 0 0 22px; max-width: 13ch;
  }
  .radial-hero .lede {
    font-size: 17px; line-height: 1.6; color: rgba(255,255,255,.62);
    max-width: 66ch; margin: 0;
  }
  .radial-scale-wrap { overflow: hidden; width: 100%; }
  .radial-wrap {
    position: relative;
    width: 960px; height: 800px;
    margin: 0 auto;
    transform-origin: top center;
  }
  .radial-svg {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    pointer-events: none; overflow: visible;
  }
  .radial-center {
    position: absolute;
    width: 252px; height: 252px;
    left: 480px; top: 400px;
    transform: translate(-50%, -50%);
    display: flex; align-items: center; justify-content: center;
  }
  .radial-center-ring {
    position: absolute; inset: -22px; border-radius: 50%;
    border: 1px solid rgba(18,131,221,.35);
    animation: ring-pulse 3s ease-in-out infinite;
  }
  .radial-center-ring-2 {
    position: absolute; inset: -48px; border-radius: 50%;
    border: 1px solid rgba(18,131,221,.18);
    animation: ring-pulse 3s ease-in-out infinite 1s;
  }
  .radial-center-ring-3 {
    position: absolute; inset: -76px; border-radius: 50%;
    border: 1px solid rgba(18,131,221,.08);
  }
  .radial-center-glow {
    position: absolute; inset: -30px; border-radius: 50%;
    background: radial-gradient(circle, rgba(18,131,221,0.22) 0%, transparent 70%);
    pointer-events: none;
  }
  @@keyframes ring-pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(1.04); }
  }
  @@media (prefers-reduced-motion: reduce) {
    .radial-center-ring, .radial-center-ring-2 { animation: none; }
  }
  .radial-center img {
    width: 100%; height: 100%; object-fit: contain;
    position: relative; z-index: 1;
  }

  .cap-node {
    position: absolute;
    width: 224px;
    background: rgba(255,255,255,0.97);
    border: 1px solid rgba(255,255,255,0.25);
    border-top: 2px solid transparent;
    border-radius: 12px;
    padding: 18px 16px 14px;
    text-decoration: none; color: inherit;
    transition: border-color 150ms, box-shadow 150ms, transform 150ms;
    display: flex; flex-direction: column; gap: 6px;
    box-shadow: 0 2px 12px rgba(0,0,0,0.22), 0 1px 3px rgba(0,0,0,0.14);
  }
  .cap-node:hover {
    border-color: rgba(18,131,221,0.3);
    border-top-color: #1283DD;
    box-shadow: 0 8px 28px rgba(0,0,0,0.32), 0 2px 6px rgba(18,131,221,0.25);
    transform: translateY(-3px);
  }
  .cap-node-count { display: none; }
  .radial-hero-bg {
    position: absolute; inset: 0;
    z-index: 0; pointer-events: none;
    overflow: hidden;
  }
  .radial-hero-bg > div {
    position: absolute;
    width: 1200px; height: 100%;
    left: 50%; transform: translateX(-50%);
  }
  .cap-node-name {
    font-family: var(--font-display); font-weight: 600; font-size: 18px;
    letter-spacing: -.010em; color: var(--ink); line-height: 1.2;
  }
  .cap-node-desc {
    font-size: 11.5px; color: var(--ink-3); line-height: 1.5;
    margin: 2px 0 4px;
  }
  .cap-node-cta {
    font-family: var(--font-mono);
    font-size: 9.5px; font-weight: 500; letter-spacing: .08em; text-transform: uppercase;
    color: var(--hana-blue); display: inline-flex; align-items: center; gap: 4px;
    margin-top: 2px;
  }
  @@media (max-width: 640px) {
    .radial-hero h1 { font-size: 36px; }
  }
</style>

<section class="radial-section" id="radial-hero">
  <div class="radial-hero-bg" id="radial-hero-bg"></div>
  <div class="radial-hero">
    <div class="radial-eyebrow">Capabilities</div>
    <h1>End to End Capabilities With Hana</h1>
    <p class="lede">From a fine-pitch surface-mount line through die-level packaging and test to the finished, tested unit &mdash; the same qualified processes run across our plants in China, Thailand, Cambodia and the USA.</p>
  </div>
  <div class="radial-scale-wrap"><div class="radial-wrap" id="radial-wrap">

    <svg class="radial-svg" id="radial-svg" xmlns="http://www.w3.org/2000/svg"></svg>

    <div class="radial-center" id="radial-center">
      <div class="radial-center-ring-3"></div>
      <div class="radial-center-ring-2"></div>
      <div class="radial-center-ring"></div>
      <div class="radial-center-glow"></div>
      <img src="~/images/hana-mark.svg" alt="Hana Microelectronics" />
    </div>

    <div class="cap-nodes-fallback" id="cap-nodes" style="display:contents">

      <a class="cap-node" href="/capabilities/pcba-box-build" data-cap-index="0">
        <div class="cap-node-count">3 Processes</div>
        <div class="cap-node-name">PCBA &amp; Box Build</div>
        <p class="cap-node-desc">Board assembly and full product assembly under one group — from a fine-pitch surface-mount line through bare-die work to the finished, tested unit.</p>
        <span class="cap-node-cta">Explore &rarr;</span>
      </a>

      <a class="cap-node" href="/capabilities/osat" data-cap-index="1">
        <div class="cap-node-count">6 Processes</div>
        <div class="cap-node-name">OSAT</div>
        <p class="cap-node-desc">Packaging and test at the die level — wafer processing, die attach, wire bond, flip chip and final test under one roof.</p>
        <span class="cap-node-cta">Explore &rarr;</span>
      </a>

      <a class="cap-node" href="/capabilities/microelectronic-assembly" data-cap-index="2">
        <div class="cap-node-count">4 Processes</div>
        <div class="cap-node-name">Microelectronic Assembly</div>
        <p class="cap-node-desc">The precision end of the group — flip chip, MEMS and sensor assembly, fine interconnect and micro-assembly, where placement is measured in microns.</p>
        <span class="cap-node-cta">Explore &rarr;</span>
      </a>

      <a class="cap-node" href="/capabilities/rfid-smart-tags" data-cap-index="3">
        <div class="cap-node-count">2 Processes</div>
        <div class="cap-node-name">RFID &amp; Smart Tags</div>
        <p class="cap-node-desc">High-volume RFID inlays and ruggedized tags — coil and antenna assembly, chip attach and lamination, built for environments that destroy ordinary labels.</p>
        <span class="cap-node-cta">Explore &rarr;</span>
      </a>

      <a class="cap-node" href="/capabilities/automation" data-cap-index="4">
        <div class="cap-node-count">3 Processes</div>
        <div class="cap-node-name">Automation</div>
        <p class="cap-node-desc">The inspection, handling and data layer that runs underneath every line — in-line optical inspection, robotic handling and unit-level traceability.</p>
        <span class="cap-node-cta">Explore &rarr;</span>
      </a>

      <a class="cap-node" href="/capabilities/dfx-jdm" data-cap-index="5">
        <div class="cap-node-count">3 Processes</div>
        <div class="cap-node-name">DFx &amp; JDM Collaboration</div>
        <p class="cap-node-desc">How we work with your engineering team before volume — design-for-excellence review, joint development and new product introduction.</p>
        <span class="cap-node-cta">Explore &rarr;</span>
      </a>

    </div>
  </div></div>
</section>

<section data-hana-bg="halftone" data-variant="dark" data-accent="" data-fade="none" style="background:var(--hana-blue-deep);color:#fff;position:relative;overflow:hidden;">
  <div style="max-width:1080px;margin:0 auto;padding:72px 32px;text-align:center;position:relative;z-index:1;">
    <h2 class="hana-h2" style="color:#fff;margin:0 auto 16px;max-width:640px;">Tell us what you&rsquo;re building</h2>
    <p style="font-size:17px;line-height:1.6;color:rgba(255,255,255,0.8);max-width:560px;margin:0 auto 32px;">Send a BOM or a design file and our engineering team will point you to the right process.</p>
    <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;">
      <a href="/contact/rfq" class="hana-btn hana-btn-on-dark">Request a quote</a>
    </div>
  </div>
</section>

@section Scripts {
<script>
(function () {
  const WRAP_W = 960, WRAP_H = 800;
  const CX = 480, CY = 400;
  const R = 300;
  const CARD_W = 224;
  const START_ANGLE = -90;

  function toRad(deg) { return deg * Math.PI / 180; }

  function positionNodes() {
    const wrap = document.getElementById('radial-wrap');
    if (!wrap) return;
    if (window.innerWidth < 980) return;

    const nodes = wrap.querySelectorAll('.cap-node');
    const svg = document.getElementById('radial-svg');
    svg.innerHTML = '';

    nodes.forEach((node, i) => {
      const angle = START_ANGLE + i * 60;
      const rad = toRad(angle);
      const cardCX = CX + R * Math.cos(rad);
      const cardCY = CY + R * Math.sin(rad);
      const cardH = node.offsetHeight || 170;
      node.style.left = (cardCX - CARD_W / 2) + 'px';
      node.style.top = (cardCY - cardH / 2) + 'px';

      const dx = cardCX - CX, dy = cardCY - CY;
      const dist = Math.sqrt(dx * dx + dy * dy);
      const ux = dx / dist, uy = dy / dist;

      const x1 = CX + ux * 93;
      const y1 = CY + uy * 62;

      const halfW = CARD_W / 2, halfH = cardH / 2;
      const ex = Math.max(-halfW, Math.min(halfW, -ux * halfW / Math.max(Math.abs(ux), Math.abs(uy) * halfW / halfH)));
      const ey = Math.max(-halfH, Math.min(halfH, -uy * halfH / Math.max(Math.abs(uy), Math.abs(ux) * halfH / halfW)));
      const x2 = cardCX + ex;
      const y2 = cardCY + ey;

      const line = document.createElementNS('http://www.w3.org/2000/svg', 'line');
      line.setAttribute('x1', x1); line.setAttribute('y1', y1);
      line.setAttribute('x2', x2); line.setAttribute('y2', y2);
      line.setAttribute('stroke', '#7EC8FF'); line.setAttribute('stroke-width', '1');
      line.setAttribute('stroke-opacity', '0.35');
      line.setAttribute('stroke-dasharray', '4 4');
      svg.appendChild(line);

      const dot = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
      dot.setAttribute('cx', x2); dot.setAttribute('cy', y2);
      dot.setAttribute('r', '3'); dot.setAttribute('fill', '#7EC8FF');
      dot.setAttribute('fill-opacity', '0.6');
      svg.appendChild(dot);
    });
  }

  function applyGlobe() {
    const outer = document.getElementById('radial-hero-bg');
    if (!outer || !window.HanaBG) return;
    let inner = outer.querySelector('div');
    if (!inner) { inner = document.createElement('div'); outer.appendChild(inner); }
    HanaBG.apply(inner, { pattern: 'globe', variant: 'dark', accent: 'cyan', fade: 'none' });
    document.getElementById('radial-hero').style.background = 'radial-gradient(ellipse 80% 100% at 80% 50%, #072c4d 0%, #030a17 65%)';
  }

  function scaleRadial() {
    const wrap = document.getElementById('radial-wrap');
    if (!wrap) return;
    const available = wrap.parentElement.clientWidth;
    const scale = Math.min(1, available / 960);
    wrap.style.transform = 'scale(' + scale + ')';
    wrap.style.marginBottom = ((scale - 1) * 800) + 'px';
  }

  function run() { applyGlobe(); scaleRadial(); positionNodes(); }
  if (document.readyState === 'complete') { setTimeout(run, 100); }
  else { window.addEventListener('load', () => setTimeout(run, 100)); }
  window.addEventListener('resize', () => { scaleRadial(); positionNodes(); });
})();
</script>
}
