        <ul style="list-style:none;padding:0;margin:0 0 16px;"><li style="display:grid;grid-template-columns:16px 1fr;gap:8px;align-items:baseline;padding:6px 0;"><span style="color:var(--hana-blue);font-weight:700;">&rsaquo;</span><span style="font-family:var(--font-text);font-size:13px;color:var(--ink-2);line-height:1.5;">C4 solder bump and Cu-pillar</span></li><li style="display:grid;grid-template-columns:16px 1fr;gap:8px;align-items:baseline;padding:6px 0;"><span style="color:var(--hana-blue);font-weight:700;">&rsaquo;</span><span style="font-family:var(--font-text);font-size:13px;color:var(--ink-2);line-height:1.5;">Bump pitch down to 80 µm</span></li><li style="display:grid;grid-template-columns:16px 1fr;gap:8px;align-items:baseline;padding:6px 0;"><span style="color:var(--hana-blue);font-weight:700;">&rsaquo;</span><span style="font-family:var(--font-text);font-size:13px;color:var(--ink-2);line-height:1.5;">Mass reflow and thermo-compression</span></li><li style="display:grid;grid-template-columns:16px 1fr;gap:8px;align-items:baseline;padding:6px 0;"><span style="color:var(--hana-blue);font-weight:700;">&rsaquo;</span><span style="font-family:var(--font-text);font-size:13px;color:var(--ink-2);line-height:1.5;">Face-down placement to ±10 µm</span></li></ul>
