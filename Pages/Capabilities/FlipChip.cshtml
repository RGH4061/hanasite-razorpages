        <ul style="list-style:none;padding:0;margin:0 0 16px;"><li style="display:grid;grid-template-columns:16px 1fr;gap:8px;align-items:baseline;padding:6px 0;"><span style="color:var(--hana-blue);font-weight:700;">&rsaquo;</span><span style="font-family:var(--font-text);font-size:13px;color:var(--ink-2);line-height:1.5;">Capillary (CUF) and no-flow (NUF)</span></li><li style="display:grid;grid-template-columns:16px 1fr;gap:8px;align-items:baseline;padding:6px 0;"><span style="color:var(--hana-blue);font-weight:700;">&rsaquo;</span><span style="font-family:var(--font-text);font-size:13px;color:var(--ink-2);line-height:1.5;">Edge-bond and corner-bond options</span></li><li style="display:grid;grid-template-columns:16px 1fr;gap:8px;align-items:baseline;padding:6px 0;"><span style="color:var(--hana-blue);font-weight:700;">&rsaquo;</span><span style="font-family:var(--font-text);font-size:13px;color:var(--ink-2);line-height:1.5;">Void control verified by X-ray</span></li><li style="display:grid;grid-template-columns:16px 1fr;gap:8px;align-items:baseline;padding:6px 0;"><span style="color:var(--hana-blue);font-weight:700;">&rsaquo;</span><span style="font-family:var(--font-text);font-size:13px;color:var(--ink-2);line-height:1.5;">Profiles tuned to AEC-Q reliability</span></li></ul>
        <div style="margin-top:auto;padding-top:14px;border-top:1px solid var(--line);display:flex;flex-direction:column;gap:10px;"><div><div style="font-size:9.5px;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:var(--ink-3);margin-bottom:3px;">Underfill</div><div style="font-size:12.5px;color:var(--ink);font-weight:600;font-family:var(--font-mono);line-height:1.3;">CUF / NUF</div></div><div><div style="font-size:9.5px;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:var(--ink-3);margin-bottom:3px;">Void check</div><div style="font-size:12.5px;color:var(--ink);font-weight:600;font-family:var(--font-mono);line-height:1.3;">3D X-ray</div></div></div>
      </div>
    </div>
      <div class="sc-pillar" style="border:1px solid var(--line);border-radius:var(--radius-card);overflow:hidden;background:#fff;display:flex;flex-direction:column;">
      <div style="position:relative;"><div style="position:relative;overflow:hidden;border-radius:0px;border:1px solid var(--line);background:var(--surface);width:100%;height:150px;display:flex;align-items:center;justify-content:center;background-image:repeating-linear-gradient(45deg,transparent 0 13px,rgba(18,131,221,0.06) 13px 14px);"><div style="position:absolute;top:10px;left:12px;width:18px;height:18px;opacity:.4;"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--hana-blue)" stroke-width="1.5"><circle cx="12" cy="12" r="9"></circle><path d="M12 3v4M12 17v4M3 12h4M17 12h4"></path></svg></div><span style="font-family:var(--font-mono);font-size:11px;color:var(--ink-3);text-align:center;padding:0 18px;line-height:1.5;">[ 3D X-ray of a flip-chip joint array ]</span></div><div style="position:absolute;top:12px;left:12px;width:34px;height:34px;border-radius:8px;background:var(--hana-blue);color:#fff;display:flex;align-items:center;justify-content:center;box-shadow:0 2px 8px rgba(3,10,23,.25);"><i data-lucide="shield" style="width:18px;height:18px;"></i></div></div>
