@page "/capabilities/pcba-box-build/cob-assembly"
@{
    ViewData["Title"] = "COB Assembly — capabilities";
    ViewData["Description"] = "Bare-die attach, wire bonding, and encapsulation directly onto the board — the lowest-profile, lowest-cost route for high-volume modules, qualified across three countries.";
}

@* Chip-on-board assembly — sub-capability detail page. FAQ uses native <details>;
   section backgrounds via ~/js/hana-backgrounds.js. *@

<style>
  .sc-pillar{ transition:border-color 180ms ease, box-shadow 180ms ease, transform 180ms ease; }
  .sc-pillar:hover{ border-color:color-mix(in srgb, var(--hana-blue) 55%, var(--line)) !important; box-shadow:0 6px 18px rgba(18,131,221,.10); transform:translateY(-2px); }
  .sc-pillars-band > .hana-bg-layer{ opacity:.55 !important; background:transparent !important; }
  details.sc-faq{ border-top:1px solid var(--line); }
  details.sc-faq:first-child{ border-top:none; }
  details.sc-faq > summary{ list-style:none; cursor:pointer; padding:18px 22px; display:flex; align-items:baseline; justify-content:space-between; gap:12px; font-family:var(--font-text); font-size:15px; font-weight:600; color:var(--ink); line-height:1.4; }
  details.sc-faq > summary::-webkit-details-marker{ display:none; }
  details.sc-faq[open] > summary{ background:var(--bg); }
  .sc-faq-mk{ color:var(--hana-blue); font-size:22px; line-height:1; flex-shrink:0; transition:transform 150ms ease; }
  details.sc-faq[open] .sc-faq-mk{ transform:rotate(45deg); }
  .sc-faq-a{ padding:0 22px 20px; font-family:var(--font-text); font-size:14px; color:var(--ink-2); line-height:1.65; max-width:720px; }
</style>

<div style="border-bottom:1px solid var(--line);background:var(--bg);">
  <div style="max-width:1240px;margin:0 auto;padding:11px 32px;font-size:12.5px;color:var(--ink-3);display:flex;gap:8px;align-items:center;flex-wrap:wrap;">
    <a href="/capabilities" class="hana-link" style="font-size:12.5px;">Capabilities</a>
    <span style="color:var(--line);">&rsaquo;</span>
    <a href="/capabilities/pcba-box-build" class="hana-link" style="font-size:12.5px;">PCBA & Box Build</a>
    <span style="color:var(--line);">&rsaquo;</span>
    <span style="color:var(--ink);font-weight:600;">COB Assembly</span>
  </div>
</div>

<div style="background:#fff;position:relative;z-index:1;"><div style="max-width:1000px;margin:0 auto;padding:56px 48px 40px;"><div style="margin-bottom:64px;">
    <div style="font-family:var(--font-text);font-size:10px;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;color:var(--hana-blue);margin-bottom:14px;">PCBA & Box Build · Sub-capability</div>
    <h1 style="font-family:var(--font-display);font-size:46px;font-weight:700;color:var(--ink);line-height:1.06;letter-spacing:-0.03em;margin:0 0 18px;max-width:740px;text-wrap:balance;">Chip-on-board assembly</h1>
    <p style="font-family:var(--font-text);font-size:18px;color:var(--ink-2);line-height:1.55;max-width:660px;margin:0 0 32px;text-wrap:pretty;">Bare-die attach, wire bonding, and encapsulation directly onto the board — the lowest-profile, lowest-cost route for high-volume modules, qualified across three countries.</p>
    <div style="position:relative;overflow:hidden;border-radius:10px;border:1px solid var(--line);background:var(--surface);width:100%;height:340px;display:flex;align-items:center;justify-content:center;background-image:repeating-linear-gradient(45deg,transparent 0 13px,rgba(18,131,221,0.06) 13px 14px);"><div style="position:absolute;top:10px;left:12px;width:18px;height:18px;opacity:.4;"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--hana-blue)" stroke-width="1.5"><circle cx="12" cy="12" r="9"></circle><path d="M12 3v4M12 17v4M3 12h4M17 12h4"></path></svg></div><span style="font-family:var(--font-mono);font-size:11px;color:var(--ink-3);text-align:center;padding:0 18px;line-height:1.5;">[ Wire-bond array under the bonder camera (COB) ]</span></div>
    <div class="hana-spec-block" style="margin-top:18px;"><div class="hana-spec-item"><div class="hana-spec-label" style="display:block;margin-bottom:8px;">Au wire</div><div class="hana-spec-value" style="font-family:var(--font-mono);font-size:22px;">18µm</div></div><div class="hana-spec-item"><div class="hana-spec-label" style="display:block;margin-bottom:8px;">Die placement</div><div class="hana-spec-value" style="font-family:var(--font-mono);font-size:22px;">±5µm</div></div><div class="hana-spec-item"><div class="hana-spec-label" style="display:block;margin-bottom:8px;">Encapsulation</div><div class="hana-spec-value" style="font-family:var(--font-mono);font-size:17px;">Glob-top</div></div><div class="hana-spec-item"><div class="hana-spec-label" style="display:block;margin-bottom:8px;">Bond inspection</div><div class="hana-spec-value" style="font-family:var(--font-mono);font-size:22px;">100%</div></div></div>
  </div></div></div>

<div class="sc-pillars-band" data-hana-bg="wafer" data-variant="light" data-accent="" data-fade="none" style="background:linear-gradient(120deg,#f5f7fa 35%,#d8e6f3 100%);position:relative;overflow:hidden;"><div style="position:relative;z-index:1;max-width:1000px;margin:0 auto;padding:8px 48px 44px;"><div style="margin-bottom:64px;"><div style="margin-bottom:26px;"><h2 style="font-family:var(--font-display);font-size:28px;font-weight:600;color:var(--ink);line-height:1.2;letter-spacing:-0.02em;margin:0;">Capability overview</h2><p style="font-family:var(--font-text);font-size:15.5px;color:var(--ink-2);line-height:1.6;max-width:640px;margin:10px 0 0;">What chip-on-board covers, and Hana’s standard envelope on each.</p></div>
    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:18px;">
      <div class="sc-pillar" style="border:1px solid var(--line);border-radius:var(--radius-card);overflow:hidden;background:#fff;display:flex;flex-direction:column;">
      <div style="position:relative;"><div style="position:relative;overflow:hidden;border-radius:0px;border:1px solid var(--line);background:var(--surface);width:100%;height:150px;display:flex;align-items:center;justify-content:center;background-image:repeating-linear-gradient(45deg,transparent 0 13px,rgba(18,131,221,0.06) 13px 14px);"><div style="position:absolute;top:10px;left:12px;width:18px;height:18px;opacity:.4;"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--hana-blue)" stroke-width="1.5"><circle cx="12" cy="12" r="9"></circle><path d="M12 3v4M12 17v4M3 12h4M17 12h4"></path></svg></div><span style="font-family:var(--font-mono);font-size:11px;color:var(--ink-3);text-align:center;padding:0 18px;line-height:1.5;">[ Epoxy die-attach head placing a bare die ]</span></div><div style="position:absolute;top:12px;left:12px;width:34px;height:34px;border-radius:8px;background:var(--hana-blue);color:#fff;display:flex;align-items:center;justify-content:center;box-shadow:0 2px 8px rgba(3,10,23,.25);"><i data-lucide="flame" style="width:18px;height:18px;"></i></div></div>
      <div style="padding:22px;display:flex;flex-direction:column;flex:1;">
        <div style="font-family:var(--font-display);font-size:20px;font-weight:600;color:var(--ink);letter-spacing:-0.01em;margin-bottom:10px;">Die attach</div>
        <p style="font-family:var(--font-text);font-size:13.5px;color:var(--ink-2);line-height:1.55;margin:0 0 16px;">Conductive and non-conductive die attach, dispensed and cured inline.</p>
        <ul style="list-style:none;padding:0;margin:0 0 16px;"><li style="display:grid;grid-template-columns:16px 1fr;gap:8px;align-items:baseline;padding:6px 0;"><span style="color:var(--hana-blue);font-weight:700;">&rsaquo;</span><span style="font-family:var(--font-text);font-size:13px;color:var(--ink-2);line-height:1.5;">Epoxy &amp; eutectic die attach</span></li><li style="display:grid;grid-template-columns:16px 1fr;gap:8px;align-items:baseline;padding:6px 0;"><span style="color:var(--hana-blue);font-weight:700;">&rsaquo;</span><span style="font-family:var(--font-text);font-size:13px;color:var(--ink-2);line-height:1.5;">Die placement accuracy to ±5 µm</span></li><li style="display:grid;grid-template-columns:16px 1fr;gap:8px;align-items:baseline;padding:6px 0;"><span style="color:var(--hana-blue);font-weight:700;">&rsaquo;</span><span style="font-family:var(--font-text);font-size:13px;color:var(--ink-2);line-height:1.5;">Multi-die and stacked-die layouts</span></li><li style="display:grid;grid-template-columns:16px 1fr;gap:8px;align-items:baseline;padding:6px 0;"><span style="color:var(--hana-blue);font-weight:700;">&rsaquo;</span><span style="font-family:var(--font-text);font-size:13px;color:var(--ink-2);line-height:1.5;">Silver-filled and insulating adhesives</span></li></ul>
        <div style="margin-top:auto;padding-top:14px;border-top:1px solid var(--line);display:flex;flex-direction:column;gap:10px;"><div><div style="font-size:9.5px;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:var(--ink-3);margin-bottom:3px;">Placement</div><div style="font-size:12.5px;color:var(--ink);font-weight:600;font-family:var(--font-mono);line-height:1.3;">±5 µm</div></div><div><div style="font-size:9.5px;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:var(--ink-3);margin-bottom:3px;">Die size</div><div style="font-size:12.5px;color:var(--ink);font-weight:600;font-family:var(--font-mono);line-height:1.3;">0.3–10 mm</div></div></div>
      </div>
    </div>
      <div class="sc-pillar" style="border:1px solid var(--line);border-radius:var(--radius-card);overflow:hidden;background:#fff;display:flex;flex-direction:column;">
      <div style="position:relative;"><div style="position:relative;overflow:hidden;border-radius:0px;border:1px solid var(--line);background:var(--surface);width:100%;height:150px;display:flex;align-items:center;justify-content:center;background-image:repeating-linear-gradient(45deg,transparent 0 13px,rgba(18,131,221,0.06) 13px 14px);"><div style="position:absolute;top:10px;left:12px;width:18px;height:18px;opacity:.4;"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--hana-blue)" stroke-width="1.5"><circle cx="12" cy="12" r="9"></circle><path d="M12 3v4M12 17v4M3 12h4M17 12h4"></path></svg></div><span style="font-family:var(--font-mono);font-size:11px;color:var(--ink-3);text-align:center;padding:0 18px;line-height:1.5;">[ Gold ball-bond loop under magnification ]</span></div><div style="position:absolute;top:12px;left:12px;width:34px;height:34px;border-radius:8px;background:var(--hana-blue);color:#fff;display:flex;align-items:center;justify-content:center;box-shadow:0 2px 8px rgba(3,10,23,.25);"><i data-lucide="ruler" style="width:18px;height:18px;"></i></div></div>
      <div style="padding:22px;display:flex;flex-direction:column;flex:1;">
        <div style="font-family:var(--font-display);font-size:20px;font-weight:600;color:var(--ink);letter-spacing:-0.01em;margin-bottom:10px;">Wire bond</div>
        <p style="font-family:var(--font-text);font-size:13.5px;color:var(--ink-2);line-height:1.55;margin:0 0 16px;">Gold and aluminium wire bonding at fine pitch, on every line.</p>
        <ul style="list-style:none;padding:0;margin:0 0 16px;"><li style="display:grid;grid-template-columns:16px 1fr;gap:8px;align-items:baseline;padding:6px 0;"><span style="color:var(--hana-blue);font-weight:700;">&rsaquo;</span><span style="font-family:var(--font-text);font-size:13px;color:var(--ink-2);line-height:1.5;">Au ball bond from 18 µm wire</span></li><li style="display:grid;grid-template-columns:16px 1fr;gap:8px;align-items:baseline;padding:6px 0;"><span style="color:var(--hana-blue);font-weight:700;">&rsaquo;</span><span style="font-family:var(--font-text);font-size:13px;color:var(--ink-2);line-height:1.5;">Al wedge bond for power devices</span></li><li style="display:grid;grid-template-columns:16px 1fr;gap:8px;align-items:baseline;padding:6px 0;"><span style="color:var(--hana-blue);font-weight:700;">&rsaquo;</span><span style="font-family:var(--font-text);font-size:13px;color:var(--ink-2);line-height:1.5;">Bond pitch down to 60 µm</span></li><li style="display:grid;grid-template-columns:16px 1fr;gap:8px;align-items:baseline;padding:6px 0;"><span style="color:var(--hana-blue);font-weight:700;">&rsaquo;</span><span style="font-family:var(--font-text);font-size:13px;color:var(--ink-2);line-height:1.5;">Pull &amp; shear tested to MIL-STD-883</span></li></ul>
        <div style="margin-top:auto;padding-top:14px;border-top:1px solid var(--line);display:flex;flex-direction:column;gap:10px;"><div><div style="font-size:9.5px;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:var(--ink-3);margin-bottom:3px;">Au wire</div><div style="font-size:12.5px;color:var(--ink);font-weight:600;font-family:var(--font-mono);line-height:1.3;">18 µm</div></div><div><div style="font-size:9.5px;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:var(--ink-3);margin-bottom:3px;">Min pitch</div><div style="font-size:12.5px;color:var(--ink);font-weight:600;font-family:var(--font-mono);line-height:1.3;">60 µm</div></div></div>
      </div>
    </div>
      <div class="sc-pillar" style="border:1px solid var(--line);border-radius:var(--radius-card);overflow:hidden;background:#fff;display:flex;flex-direction:column;">
      <div style="position:relative;"><div style="position:relative;overflow:hidden;border-radius:0px;border:1px solid var(--line);background:var(--surface);width:100%;height:150px;display:flex;align-items:center;justify-content:center;background-image:repeating-linear-gradient(45deg,transparent 0 13px,rgba(18,131,221,0.06) 13px 14px);"><div style="position:absolute;top:10px;left:12px;width:18px;height:18px;opacity:.4;"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--hana-blue)" stroke-width="1.5"><circle cx="12" cy="12" r="9"></circle><path d="M12 3v4M12 17v4M3 12h4M17 12h4"></path></svg></div><span style="font-family:var(--font-mono);font-size:11px;color:var(--ink-3);text-align:center;padding:0 18px;line-height:1.5;">[ Glob-top dispense over a bonded die ]</span></div><div style="position:absolute;top:12px;left:12px;width:34px;height:34px;border-radius:8px;background:var(--hana-blue);color:#fff;display:flex;align-items:center;justify-content:center;box-shadow:0 2px 8px rgba(3,10,23,.25);"><i data-lucide="shield" style="width:18px;height:18px;"></i></div></div>
      <div style="padding:22px;display:flex;flex-direction:column;flex:1;">
        <div style="font-family:var(--font-display);font-size:20px;font-weight:600;color:var(--ink);letter-spacing:-0.01em;margin-bottom:10px;">Encapsulation</div>
        <p style="font-family:var(--font-text);font-size:13.5px;color:var(--ink-2);line-height:1.55;margin:0 0 16px;">Glob-top and dam-and-fill encapsulation protect the die and bonds.</p>
        <ul style="list-style:none;padding:0;margin:0 0 16px;"><li style="display:grid;grid-template-columns:16px 1fr;gap:8px;align-items:baseline;padding:6px 0;"><span style="color:var(--hana-blue);font-weight:700;">&rsaquo;</span><span style="font-family:var(--font-text);font-size:13px;color:var(--ink-2);line-height:1.5;">Glob-top and dam-and-fill</span></li><li style="display:grid;grid-template-columns:16px 1fr;gap:8px;align-items:baseline;padding:6px 0;"><span style="color:var(--hana-blue);font-weight:700;">&rsaquo;</span><span style="font-family:var(--font-text);font-size:13px;color:var(--ink-2);line-height:1.5;">UV and thermal cure profiles</span></li><li style="display:grid;grid-template-columns:16px 1fr;gap:8px;align-items:baseline;padding:6px 0;"><span style="color:var(--hana-blue);font-weight:700;">&rsaquo;</span><span style="font-family:var(--font-text);font-size:13px;color:var(--ink-2);line-height:1.5;">Per-unit traceability, default</span></li><li style="display:grid;grid-template-columns:16px 1fr;gap:8px;align-items:baseline;padding:6px 0;"><span style="color:var(--hana-blue);font-weight:700;">&rsaquo;</span><span style="font-family:var(--font-text);font-size:13px;color:var(--ink-2);line-height:1.5;">IPC / MIL-STD bond verification</span></li></ul>
        <div style="margin-top:auto;padding-top:14px;border-top:1px solid var(--line);display:flex;flex-direction:column;gap:10px;"><div><div style="font-size:9.5px;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:var(--ink-3);margin-bottom:3px;">Encapsulation</div><div style="font-size:12.5px;color:var(--ink);font-weight:600;font-family:var(--font-mono);line-height:1.3;">Glob-top</div></div><div><div style="font-size:9.5px;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:var(--ink-3);margin-bottom:3px;">Verification</div><div style="font-size:12.5px;color:var(--ink);font-weight:600;font-family:var(--font-mono);line-height:1.3;">Pull · shear</div></div></div>
      </div>
    </div>
    </div>
  </div></div></div>

<div style="background:#fff;"><div style="max-width:1000px;margin:0 auto;padding:8px 48px 44px;"><div style="margin-bottom:44px;"><div style="margin-bottom:26px;"><h2 style="font-family:var(--font-display);font-size:28px;font-weight:600;color:var(--ink);line-height:1.2;letter-spacing:-0.02em;margin:0;">Why run COB with Hana</h2></div><div style="display:grid;grid-template-columns:1fr 1fr;gap:36px;align-items:center;margin-bottom:36px;">
      <div style="order:1;">
        <div style="font-family:var(--font-text);font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:var(--hana-blue);margin-bottom:10px;">Lowest profile, lowest cost</div>
        <h3 style="font-family:var(--font-display);font-size:24px;font-weight:600;color:var(--ink);line-height:1.2;letter-spacing:-0.02em;margin:0 0 12px;text-wrap:balance;">Skip the package — bond the die straight to the board</h3>
        <p style="font-family:var(--font-text);font-size:15px;color:var(--ink-2);line-height:1.6;margin:0 0 16px;max-width:460px;">For high-volume modules where height and unit cost matter, COB removes the IC package entirely and the bond goes direct to the substrate.</p>
        <ul style="list-style:none;padding:0;margin:0;"><li style="display:grid;grid-template-columns:18px 1fr;gap:10px;align-items:baseline;padding:10px 0;border-top:1px solid var(--line);"><span style="color:var(--hana-blue);font-size:15px;font-weight:700;line-height:1;">&rsaquo;</span><span style="font-family:var(--font-text);font-size:14px;color:var(--ink-2);line-height:1.55;">Thinnest possible assembly stack-up</span></li><li style="display:grid;grid-template-columns:18px 1fr;gap:10px;align-items:baseline;padding:10px 0;border-top:1px solid var(--line);"><span style="color:var(--hana-blue);font-size:15px;font-weight:700;line-height:1;">&rsaquo;</span><span style="font-family:var(--font-text);font-size:14px;color:var(--ink-2);line-height:1.55;">No package cost at volume</span></li><li style="display:grid;grid-template-columns:18px 1fr;gap:10px;align-items:baseline;padding:10px 0;border-top:1px solid var(--line);"><span style="color:var(--hana-blue);font-size:15px;font-weight:700;line-height:1;">&rsaquo;</span><span style="font-family:var(--font-text);font-size:14px;color:var(--ink-2);line-height:1.55;">Ideal for displays, sensors, and RFID</span></li><li style="display:grid;grid-template-columns:18px 1fr;gap:10px;align-items:baseline;padding:10px 0;border-top:1px solid var(--line);border-bottom:1px solid var(--line);"><span style="color:var(--hana-blue);font-size:15px;font-weight:700;line-height:1;">&rsaquo;</span><span style="font-family:var(--font-text);font-size:14px;color:var(--ink-2);line-height:1.55;">Runs alongside SMT on the same board</span></li></ul>
      </div>
      <div style="order:2;"><div style="position:relative;overflow:hidden;border-radius:10px;border:1px solid var(--line);background:var(--surface);width:100%;height:320px;display:flex;align-items:center;justify-content:center;background-image:repeating-linear-gradient(45deg,transparent 0 13px,rgba(18,131,221,0.06) 13px 14px);"><div style="position:absolute;top:10px;left:12px;width:18px;height:18px;opacity:.4;"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--hana-blue)" stroke-width="1.5"><circle cx="12" cy="12" r="9"></circle><path d="M12 3v4M12 17v4M3 12h4M17 12h4"></path></svg></div><span style="font-family:var(--font-mono);font-size:11px;color:var(--ink-3);text-align:center;padding:0 18px;line-height:1.5;">[ COB module line in operation ]</span></div></div>
    </div>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:36px;align-items:center;margin-bottom:36px;">
      <div style="order:2;">
        <div style="font-family:var(--font-text);font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:var(--hana-blue);margin-bottom:10px;">Engineering, not sales</div>
