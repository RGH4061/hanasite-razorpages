      <div style="position:relative;"><div style="position:relative;overflow:hidden;border-radius:0px;border:1px solid var(--line);background:var(--surface);width:100%;height:150px;display:flex;align-items:center;justify-content:center;background-image:repeating-linear-gradient(45deg,transparent 0 13px,rgba(18,131,221,0.06) 13px 14px);"><div style="position:absolute;top:10px;left:12px;width:18px;height:18px;opacity:.4;"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--hana-blue)" stroke-width="1.5"><circle cx="12" cy="12" r="9"></circle><path d="M12 3v4M12 17v4M3 12h4M17 12h4"></path></svg></div><span style="font-family:var(--font-mono);font-size:11px;color:var(--ink-3);text-align:center;padding:0 18px;line-height:1.5;">[ Board exiting a multi-zone reflow oven ]</span></div><div style="position:absolute;top:12px;left:12px;width:34px;height:34px;border-radius:8px;background:var(--hana-blue);color:#fff;display:flex;align-items:center;justify-content:center;box-shadow:0 2px 8px rgba(3,10,23,.25);"><i data-lucide="flame" style="width:18px;height:18px;"></i></div></div>
