        <ul style="list-style:none;padding:0;margin:0 0 16px;"><li style="display:grid;grid-template-columns:16px 1fr;gap:8px;align-items:baseline;padding:6px 0;"><span style="color:var(--hana-blue);font-weight:700;">&rsaquo;</span><span style="font-family:var(--font-text);font-size:13px;color:var(--ink-2);line-height:1.5;">Inline SPI + pre- &amp; post-reflow AOI</span></li><li style="display:grid;grid-template-columns:16px 1fr;gap:8px;align-items:baseline;padding:6px 0;"><span style="color:var(--hana-blue);font-weight:700;">&rsaquo;</span><span style="font-family:var(--font-text);font-size:13px;color:var(--ink-2);line-height:1.5;">2D &amp; 3D X-ray for BGA, BTC, PoP</span></li><li style="display:grid;grid-template-columns:16px 1fr;gap:8px;align-items:baseline;padding:6px 0;"><span style="color:var(--hana-blue);font-weight:700;">&rsaquo;</span><span style="font-family:var(--font-text);font-size:13px;color:var(--ink-2);line-height:1.5;">Full material / unit / product traceability</span></li><li style="display:grid;grid-template-columns:16px 1fr;gap:8px;align-items:baseline;padding:6px 0;"><span style="color:var(--hana-blue);font-weight:700;">&rsaquo;</span><span style="font-family:var(--font-text);font-size:13px;color:var(--ink-2);line-height:1.5;">Dedicated medical &amp; automotive lines; full ESD control</span></li></ul>
