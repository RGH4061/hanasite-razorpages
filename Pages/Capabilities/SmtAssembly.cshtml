    <div class="hana-spec-block" style="margin-top:18px;"><div class="hana-spec-item"><div class="hana-spec-label" style="display:block;margin-bottom:8px;">Capability locations</div><div class="hana-spec-value" style="font-family:var(--font-mono);font-size:22px;">4</div></div><div class="hana-spec-item"><div class="hana-spec-label" style="display:block;margin-bottom:8px;">Smallest passive</div><div class="hana-spec-value" style="font-family:var(--font-mono);font-size:22px;">01005</div></div><div class="hana-spec-item"><div class="hana-spec-label" style="display:block;margin-bottom:8px;">Min micro-BGA pitch</div><div class="hana-spec-value" style="font-family:var(--font-mono);font-size:17px;">0.2 mm</div></div><div class="hana-spec-item"><div class="hana-spec-label" style="display:block;margin-bottom:8px;">Placement accuracy</div><div class="hana-spec-value" style="font-family:var(--font-mono);font-size:17px;">±50 µm</div></div></div>
  </div></div></div>

<div class="sc-pillars-band" data-hana-bg="wafer" data-variant="light" data-accent="" data-fade="none" style="background:linear-gradient(120deg,#f5f7fa 35%,#d8e6f3 100%);position:relative;overflow:hidden;"><div style="position:relative;z-index:1;max-width:1000px;margin:0 auto;padding:8px 48px 44px;"><div style="margin-bottom:64px;"><div style="margin-bottom:26px;"><h2 style="font-family:var(--font-display);font-size:28px;font-weight:600;color:var(--ink);line-height:1.2;letter-spacing:-0.02em;margin:0;">Capability overview</h2><p style="font-family:var(--font-text);font-size:15.5px;color:var(--ink-2);line-height:1.6;max-width:640px;margin:10px 0 0;">Three things an engineering buyer evaluates on an SMT line — the process, the component envelope, and how every board is inspected.</p></div>
