        <div style="margin-top:auto;padding-top:14px;border-top:1px solid var(--line);display:flex;flex-direction:column;gap:10px;"><div><div style="font-size:9.5px;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:var(--ink-3);margin-bottom:3px;">Screen-print accuracy</div><div style="font-size:12.5px;color:var(--ink);font-weight:600;font-family:var(--font-mono);line-height:1.3;">±20 µm &#64; 6σ</div></div><div><div style="font-size:9.5px;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:var(--ink-3);margin-bottom:3px;">Place accuracy</div><div style="font-size:12.5px;color:var(--ink);font-weight:600;font-family:var(--font-mono);line-height:1.3;">±18 µm</div></div></div>
