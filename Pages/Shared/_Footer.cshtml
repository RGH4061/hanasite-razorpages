@* _Footer.cshtml — Hana global footer
   Renders: main footer (logo + tagline + 4 nav columns + social + SET ticker)
            sub-footer bar (copyright + legal links)

   Requires:
     ~/images/hana-logo-full.svg
     Lucide UMD library (loaded in _Layout.cshtml)

   Spec ref: design_handoff_homepage/README.md §9
*@

<footer class="hana-footer" style="font-family:var(--font-text);">

    @* ── Main footer ───────────────────────────────────────── *@
    <div style="background:var(--bg); border-top:1px solid var(--line); color:var(--ink-2);">
        <div class="hana-wrap"
             style="padding-top:48px; padding-bottom:28px;
                    display:grid;
                    grid-template-columns:1.4fr repeat(4, 1fr);
                    gap:40px; align-items:start;">

            @* Brand column *@
            <div>
                <a href="/" aria-label="Hana Microelectronics — home">
                    <img src="~/images/hana-logo-full.svg" alt="Hana"
                         width="200" height="65"
                         style="display:block; object-fit:contain; object-position:left center;" />
                </a>

                <p style="font-family:var(--font-text); font-size:13px; line-height:1.6;
                           color:var(--ink-3); max-width:280px; margin:18px 0 18px;">
                    The leading independent EMS and OSAT company in Southeast Asia,
                    specializing in microelectronics.
                </p>

                @* LinkedIn *@
                <a href="https://www.linkedin.com/company/hana-microelectronics/"
                   rel="noopener noreferrer" target="_blank"
                   aria-label="Hana on LinkedIn"
                   style="display:inline-flex; align-items:center; justify-content:center;
                          width:32px; height:32px; border-radius:4px;
                          border:1px solid var(--line); background:#fff;
                          color:var(--ink-2); text-decoration:none;
                          transition:color 150ms ease, border-color 150ms ease;">
                    <i data-lucide="linkedin" style="width:14px; height:14px;"></i>
                </a>

                @* SET ticker *@
                <div style="font-family:var(--font-mono); font-size:12px;
                             color:var(--ink-3); margin-top:18px; line-height:1.7;">
                    <div>SET-listed &middot; Bangkok</div>
                    <div>
                        HANA &middot; ฿24.50
                        <span style="color:var(--success); margin-left:4px;">+1.24%</span>
                    </div>
                </div>
            </div>

            @* Markets *@
            <div>
                <div style="font-family:var(--font-text); font-size:12px; font-weight:600;
                             text-transform:uppercase; letter-spacing:0.1em;
                             color:var(--ink); margin-bottom:12px;">Markets</div>
                <ul style="list-style:none; margin:0; padding:0;
                            display:flex; flex-direction:column; gap:5px;">
                    <li><a href="/markets/automotive"       style="font-size:13px; color:var(--ink-2); text-decoration:none; transition:color 150ms ease;" onmouseover="this.style.color='var(--hana-blue)'" onmouseout="this.style.color='var(--ink-2)'">Automotive</a></li>
                    <li><a href="/markets/industrial-iot"   style="font-size:13px; color:var(--ink-2); text-decoration:none; transition:color 150ms ease;" onmouseover="this.style.color='var(--hana-blue)'" onmouseout="this.style.color='var(--ink-2)'">Industrial &amp; IoT</a></li>
                    <li><a href="/markets/telecom"          style="font-size:13px; color:var(--ink-2); text-decoration:none; transition:color 150ms ease;" onmouseover="this.style.color='var(--hana-blue)'" onmouseout="this.style.color='var(--ink-2)'">Telecommunications</a></li>
                    <li><a href="/markets/rfid"             style="font-size:13px; color:var(--ink-2); text-decoration:none; transition:color 150ms ease;" onmouseover="this.style.color='var(--hana-blue)'" onmouseout="this.style.color='var(--ink-2)'">RFID</a></li>
                    <li><a href="/markets/optical-sensors"  style="font-size:13px; color:var(--ink-2); text-decoration:none; transition:color 150ms ease;" onmouseover="this.style.color='var(--hana-blue)'" onmouseout="this.style.color='var(--ink-2)'">Optical &amp; sensors</a></li>
                    <li><a href="/markets/consumer"         style="font-size:13px; color:var(--ink-2); text-decoration:none; transition:color 150ms ease;" onmouseover="this.style.color='var(--hana-blue)'" onmouseout="this.style.color='var(--ink-2)'">Consumer electronics</a></li>
                    <li><a href="/markets/medical"          style="font-size:13px; color:var(--ink-2); text-decoration:none; transition:color 150ms ease;" onmouseover="this.style.color='var(--hana-blue)'" onmouseout="this.style.color='var(--ink-2)'">Medical</a></li>
                    <li><a href="/markets/access-control"   style="font-size:13px; color:var(--ink-2); text-decoration:none; transition:color 150ms ease;" onmouseover="this.style.color='var(--hana-blue)'" onmouseout="this.style.color='var(--ink-2)'">Access control</a></li>
                    <li><a href="/markets/power-management" style="font-size:13px; color:var(--ink-2); text-decoration:none; transition:color 150ms ease;" onmouseover="this.style.color='var(--hana-blue)'" onmouseout="this.style.color='var(--ink-2)'">Power management</a></li>
                    <li><a href="/markets/data-centers"     style="font-size:13px; color:var(--ink-2); text-decoration:none; transition:color 150ms ease;" onmouseover="this.style.color='var(--hana-blue)'" onmouseout="this.style.color='var(--ink-2)'">Data Centers</a></li>
                </ul>
            </div>

            @* Capabilities *@
            <div>
                <div style="font-family:var(--font-text); font-size:12px; font-weight:600;
                             text-transform:uppercase; letter-spacing:0.1em;
                             color:var(--ink); margin-bottom:12px;">Capabilities</div>
                <ul style="list-style:none; margin:0; padding:0;
                            display:flex; flex-direction:column; gap:5px;">
                    <li><a href="/capabilities/pcba-box-build"           style="font-size:13px; color:var(--ink-2); text-decoration:none; transition:color 150ms ease;" onmouseover="this.style.color='var(--hana-blue)'" onmouseout="this.style.color='var(--ink-2)'">PCBA &amp; Box Build</a></li>
                    <li><a href="/capabilities/osat"                     style="font-size:13px; color:var(--ink-2); text-decoration:none; transition:color 150ms ease;" onmouseover="this.style.color='var(--hana-blue)'" onmouseout="this.style.color='var(--ink-2)'">OSAT</a></li>
                    <li><a href="/capabilities/microelectronic-assembly" style="font-size:13px; color:var(--ink-2); text-decoration:none; transition:color 150ms ease;" onmouseover="this.style.color='var(--hana-blue)'" onmouseout="this.style.color='var(--ink-2)'">Microelectronic Assembly</a></li>
                    <li><a href="/capabilities/rfid-smart-tags"          style="font-size:13px; color:var(--ink-2); text-decoration:none; transition:color 150ms ease;" onmouseover="this.style.color='var(--hana-blue)'" onmouseout="this.style.color='var(--ink-2)'">RFID &amp; Smart Tags</a></li>
                    <li><a href="/capabilities/automation"               style="font-size:13px; color:var(--ink-2); text-decoration:none; transition:color 150ms ease;" onmouseover="this.style.color='var(--hana-blue)'" onmouseout="this.style.color='var(--ink-2)'">Automation</a></li>
                    <li><a href="/capabilities/dfx-jdm"                  style="font-size:13px; color:var(--ink-2); text-decoration:none; transition:color 150ms ease;" onmouseover="this.style.color='var(--hana-blue)'" onmouseout="this.style.color='var(--ink-2)'">DFx &amp; JDM Collaboration</a></li>
                </ul>
            </div>

            @* Company *@
            <div>
                <div style="font-family:var(--font-text); font-size:12px; font-weight:600;
                             text-transform:uppercase; letter-spacing:0.1em;
                             color:var(--ink); margin-bottom:12px;">Company</div>
                <ul style="list-style:none; margin:0; padding:0;
                            display:flex; flex-direction:column; gap:5px;">
                    <li><a href="/about"          style="font-size:13px; color:var(--ink-2); text-decoration:none; transition:color 150ms ease;" onmouseover="this.style.color='var(--hana-blue)'" onmouseout="this.style.color='var(--ink-2)'">About</a></li>
                    <li><a href="/about/why-hana" style="font-size:13px; color:var(--ink-2); text-decoration:none; transition:color 150ms ease;" onmouseover="this.style.color='var(--hana-blue)'" onmouseout="this.style.color='var(--ink-2)'">Why Hana</a></li>
                    <li><a href="/locations"      style="font-size:13px; color:var(--ink-2); text-decoration:none; transition:color 150ms ease;" onmouseover="this.style.color='var(--hana-blue)'" onmouseout="this.style.color='var(--ink-2)'">Locations</a></li>
                    <li><a href="/sustainability" style="font-size:13px; color:var(--ink-2); text-decoration:none; transition:color 150ms ease;" onmouseover="this.style.color='var(--hana-blue)'" onmouseout="this.style.color='var(--ink-2)'">Sustainability</a></li>
                    <li><a href="/news"           style="font-size:13px; color:var(--ink-2); text-decoration:none; transition:color 150ms ease;" onmouseover="this.style.color='var(--hana-blue)'" onmouseout="this.style.color='var(--ink-2)'">News</a></li>
                    <li><a href="/careers"        style="font-size:13px; color:var(--ink-2); text-decoration:none; transition:color 150ms ease;" onmouseover="this.style.color='var(--hana-blue)'" onmouseout="this.style.color='var(--ink-2)'">Careers</a></li>
                </ul>
            </div>

            @* Investors *@
            <div>
                <div style="font-family:var(--font-text); font-size:12px; font-weight:600;
                             text-transform:uppercase; letter-spacing:0.1em;
                             color:var(--ink); margin-bottom:12px;">Investors</div>
                <ul style="list-style:none; margin:0; padding:0;
                            display:flex; flex-direction:column; gap:5px;">
                    <li><a href="/investor-relations"             style="font-size:13px; color:var(--ink-2); text-decoration:none; transition:color 150ms ease;" onmouseover="this.style.color='var(--hana-blue)'" onmouseout="this.style.color='var(--ink-2)'">SET: HANA</a></li>
                    <li><a href="/investor-relations/financials"  style="font-size:13px; color:var(--ink-2); text-decoration:none; transition:color 150ms ease;" onmouseover="this.style.color='var(--hana-blue)'" onmouseout="this.style.color='var(--ink-2)'">Financial reports</a></li>
                    <li><a href="/investor-relations/annual"      style="font-size:13px; color:var(--ink-2); text-decoration:none; transition:color 150ms ease;" onmouseover="this.style.color='var(--hana-blue)'" onmouseout="this.style.color='var(--ink-2)'">Annual reports</a></li>
                    <li><a href="/investor-relations/governance"  style="font-size:13px; color:var(--ink-2); text-decoration:none; transition:color 150ms ease;" onmouseover="this.style.color='var(--hana-blue)'" onmouseout="this.style.color='var(--ink-2)'">Governance</a></li>
                    <li><a href="/investor-relations/contact"     style="font-size:13px; color:var(--ink-2); text-decoration:none; transition:color 150ms ease;" onmouseover="this.style.color='var(--hana-blue)'" onmouseout="this.style.color='var(--ink-2)'">IR contact</a></li>
                </ul>
            </div>

        </div>
    </div>

    @* ── Sub-footer bar ─────────────────────────────────────── *@
    <div style="background:var(--hana-blue-deep); color:rgba(255,255,255,0.7);
                font-size:11px; font-family:var(--font-text);">
        <div class="hana-wrap"
             style="padding-top:10px; padding-bottom:10px;
                    display:flex; justify-content:space-between;
                    flex-wrap:wrap; gap:12px; align-items:center;">

            <span>&copy; 2026 Hana Microelectronics Public Company Limited.</span>

            <nav aria-label="Legal links"
                 style="display:flex; gap:22px; list-style:none; margin:0; padding:0;">
                <a href="/privacy"  style="color:inherit; text-decoration:none; transition:color 150ms ease;" onmouseover="this.style.color='#fff'" onmouseout="this.style.color=''">Privacy</a>
                <a href="/terms"    style="color:inherit; text-decoration:none; transition:color 150ms ease;" onmouseover="this.style.color='#fff'" onmouseout="this.style.color=''">Terms</a>
                <a href="/cookies"  style="color:inherit; text-decoration:none; transition:color 150ms ease;" onmouseover="this.style.color='#fff'" onmouseout="this.style.color=''">Cookies</a>
                <a href="/sitemap"  style="color:inherit; text-decoration:none; transition:color 150ms ease;" onmouseover="this.style.color='#fff'" onmouseout="this.style.color=''">Sitemap</a>
            </nav>

        </div>
    </div>

</footer>
