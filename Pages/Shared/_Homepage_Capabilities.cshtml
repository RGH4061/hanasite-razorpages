@* _Homepage_Capabilities.cshtml — Capability icon carousel
   Sits inside the shared bg wrapper in Index.cshtml (same bg as Markets).
   Requires:
     wwwroot/js/capability-carousel.js
     Pages/Shared/_Icon_Pcb.cshtml, _Icon_Chip.cshtml, _Icon_Micro.cshtml,
                  _Icon_Gear.cshtml, _Icon_Merge.cshtml, _Icon_Rfid.cshtml

   Spec ref: design_handoff_homepage/README.md §6
*@

<section class="hana-capabilities-section"
         style="position:relative; z-index:1; padding:30px 0 96px;">
    <div class="hana-wrap">

        @* ── Section header ──────────────────────────────── *@
        <div style="margin-bottom:40px;">
            <div class="hana-spec-label" style="margin-bottom:12px;">Capabilities</div>
            <h2 class="hana-h2" style="margin-bottom:8px;">Or browse by capability.</h2>
            <p class="hana-body" style="color:var(--ink-2);">
                Six capability families spanning PCBA, OSAT, microelectronics, RFID, automation, and DFx.
            </p>
        </div>

        @* ── Carousel ─────────────────────────────────────── *@
        <div class="hana-carousel" data-carousel>

            @* Arrow controls — above-right of track *@
            <div class="hana-carousel__controls"
                 style="display:flex; justify-content:flex-end; gap:8px; margin-bottom:12px;">
                <button class="hana-carousel-btn" data-carousel-prev
                        aria-label="Scroll capabilities left">
                    <svg width="14" height="14" viewBox="0 0 24 24"
                         fill="none" stroke="currentColor" stroke-width="2.5"
                         stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <path d="M19 12H5" /><path d="M12 5l-7 7 7 7" />
                    </svg>
                </button>
                <button class="hana-carousel-btn is-active" data-carousel-next
                        aria-label="Scroll capabilities right">
                    <svg width="14" height="14" viewBox="0 0 24 24"
                         fill="none" stroke="currentColor" stroke-width="2.5"
                         stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <path d="M5 12h14" /><path d="M12 5l7 7-7 7" />
                    </svg>
                </button>
            </div>

            @* Scrollable track *@
            <div class="hana-carousel__track" data-carousel-track
                 style="display:grid;
                        grid-template-columns:repeat(6, calc(20% - 9.6px));
                        gap:12px;
                        overflow-x:auto;
                        scrollbar-width:none;
                        -ms-overflow-style:none;">

                @* PCBA / Box Build *@
                <a href="/capabilities/pcba-box-build" class="hana-cap-card">
                    <div class="hana-cap-card__top">
                        <span class="hana-arrow-reveal" aria-hidden="true">
                            <i data-lucide="arrow-right"
                               style="width:13px; height:13px; color:var(--hana-blue);"></i>
                        </span>
                    </div>
                    <div class="hana-cap-card__icon-area">
                        <partial name="_Icon_Pcb" />
                    </div>
                    <div class="hana-cap-card__body">
                        <h3 class="hana-cap-card__title">PCBA / Box build</h3>
                        <p class="hana-cap-card__desc">
                            End-to-end electronics manufacturing. SMT, through-hole, box build, system integration.
                        </p>
                    </div>
                </a>

                @* OSAT *@
                <a href="/capabilities/osat" class="hana-cap-card">
                    <div class="hana-cap-card__top">
                        <span class="hana-arrow-reveal" aria-hidden="true">
                            <i data-lucide="arrow-right"
                               style="width:13px; height:13px; color:var(--hana-blue);"></i>
                        </span>
                    </div>
                    <div class="hana-cap-card__icon-area">
                        <partial name="_Icon_Chip" />
                    </div>
                    <div class="hana-cap-card__body">
                        <h3 class="hana-cap-card__title">OSAT</h3>
                        <p class="hana-cap-card__desc">
                            Outsourced semiconductor assembly and test — die attach, wire bonding, flip chip, final test.
                        </p>
                    </div>
                </a>

                @* Microelectronics *@
                <a href="/capabilities/microelectronic-assembly" class="hana-cap-card">
                    <div class="hana-cap-card__top">
                        <span class="hana-arrow-reveal" aria-hidden="true">
                            <i data-lucide="arrow-right"
                               style="width:13px; height:13px; color:var(--hana-blue);"></i>
                        </span>
                    </div>
                    <div class="hana-cap-card__icon-area">
                        <partial name="_Icon_Micro" />
                    </div>
                    <div class="hana-cap-card__body">
                        <h3 class="hana-cap-card__title">Microelectronic Assembly</h3>
                        <p class="hana-cap-card__desc">
                            Hybrid microcircuits, MEMS, sensors, and precision interconnect.
                        </p>
                    </div>
                </a>

                @* Automation *@
                <a href="/capabilities/automation" class="hana-cap-card">
                    <div class="hana-cap-card__top">
                        <span class="hana-arrow-reveal" aria-hidden="true">
                            <i data-lucide="arrow-right"
                               style="width:13px; height:13px; color:var(--hana-blue);"></i>
                        </span>
                    </div>
                    <div class="hana-cap-card__icon-area">
                        <partial name="_Icon_Gear" />
                    </div>
                    <div class="hana-cap-card__body">
                        <h3 class="hana-cap-card__title">Automation</h3>
                        <p class="hana-cap-card__desc">
                            Automated SMT lines, in-line AOI, and robotics-augmented box build for repeatable yield at volume.
                        </p>
                    </div>
                </a>

                @* RFID & Smart Tags *@
                <a href="/capabilities/rfid-smart-tags" class="hana-cap-card">
                    <div class="hana-cap-card__top">
                        <span class="hana-arrow-reveal" aria-hidden="true">
                            <i data-lucide="arrow-right"
                               style="width:13px; height:13px; color:var(--hana-blue);"></i>
                        </span>
                    </div>
                    <div class="hana-cap-card__icon-area">
                        <partial name="_Icon_Rfid" />
                    </div>
                    <div class="hana-cap-card__body">
                        <h3 class="hana-cap-card__title">RFID &amp; Smart Tags</h3>
                        <p class="hana-cap-card__desc">
                            High-volume RFID and smart-label inlay manufacturing for retail, logistics, and tire ID.
                        </p>
                    </div>
                </a>

                @* DFx & JDM Collaboration *@
                <a href="/capabilities/dfx-jdm" class="hana-cap-card">
                    <div class="hana-cap-card__top">
                        <span class="hana-arrow-reveal" aria-hidden="true">
                            <i data-lucide="arrow-right"
                               style="width:13px; height:13px; color:var(--hana-blue);"></i>
                        </span>
                    </div>
                    <div class="hana-cap-card__icon-area">
                        <partial name="_Icon_Merge" />
                    </div>
                    <div class="hana-cap-card__body">
                        <h3 class="hana-cap-card__title">DFx &amp; JDM Collaboration</h3>
                        <p class="hana-cap-card__desc">
                            Engineering teams embedded from NPI through production. We speak engineer.
                        </p>
                    </div>
                </a>

            </div>@* /track *@

        </div>@* /carousel *@

    </div>
</section>

@* Hide webkit scrollbar on the track *@
<style>
    .hana-carousel__track::-webkit-scrollbar { display: none; }
</style>
