@* _Homepage_Capabilities.cshtml — Capability icon carousel
   Sits inside the shared bg wrapper in Index.cshtml (same bg as Markets).
   Requires:
     wwwroot/js/capability-carousel.js
     Pages/Shared/_Icon_Pcb.cshtml, _Icon_Chip.cshtml, _Icon_Micro.cshtml,
                  _Icon_Gear.cshtml, _Icon_Merge.cshtml, _Icon_Rfid.cshtml

   Spec ref: design_handoff_homepage/README.md §6
*@

<section class="hana-capabilities-section"
         style="position:relative; z-index:1; padding:30px 0 96px;">
    <div class="hana-wrap" data-carousel>

        @* ── Section header + carousel controls inline ────── *@
        <div style="display:flex; justify-content:space-between; align-items:flex-end; gap:24px; margin-bottom:28px; flex-wrap:wrap;">
            <div>
                <div class="hana-spec-label" style="margin-bottom:12px;">WHAT WE DO</div>
                <h2 class="hana-h2" style="margin-bottom:8px;">Browse our capabilities</h2>
                <p class="hana-body" style="color:var(--ink-2); margin:0;">
                    Hana's range of diversified capabilities has been built to provide our customer's with end to end solutions in a vertically integrated operating structure. Click to browse detailed specifications.
                </p>
            </div>
            <div class="hana-carousel__controls" style="display:flex; gap:8px; flex-shrink:0;">
                <button class="hana-carousel-btn" data-carousel-prev
                        aria-label="Scroll capabilities left">
                    <svg width="14" height="14" viewBox="0 0 24 24"
                         fill="none" stroke="currentColor" stroke-width="2.5"
                         stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <path d="M19 12H5" /><path d="M12 5l-7 7 7 7" />
                    </svg>
                </button>
                <button class="hana-carousel-btn is-active" data-carousel-next
                        aria-label="Scroll capabilities right">
                    <svg width="14" height="14" viewBox="0 0 24 24"
                         fill="none" stroke="currentColor" stroke-width="2.5"
                         stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <path d="M5 12h14" /><path d="M12 5l7 7-7 7" />
                    </svg>
                </button>
            </div>
        </div>

        @* ── Carousel ─────────────────────────────────────── *@
        <div class="hana-carousel">

            @* Scrollable track *@
            <div class="hana-carousel__track" data-carousel-track
                 style="display:grid;
                        grid-template-columns:repeat(6, calc(20% - 9.6px));
                        gap:12px;
                        overflow-x:auto;
                        scrollbar-width:none;
                        -ms-overflow-style:none;">

                @* PCBA / Box Build *@
                                <a href="/capabilities/pcba-box-build" class="hana-cap-card">
                    <div class="hana-cap-card__top">
                        <span class="hana-arrow-reveal" aria-hidden="true">
                            <i data-lucide="arrow-right"
                               style="width:13px; height:13px; color:var(--hana-blue);"></i>
                        </span>
                    </div>
                    <div class="hana-cap-card__icon-area">
                        <img class="hana-cap-icon" src="~/images/icons/pcba-box-build.png" alt="PCBA / Box build" width="88" height="88" />
                    </div>
                    <div class="hana-cap-card__body">
                        <h3 class="hana-cap-card__title">PCBA / Box Build</h3>
                        <p class="hana-cap-card__desc">
                            Populated boards through to fully assembled, tested products — one line from prototype to volume.
                        </p>
                    </div>
                </a>

                <a href="/capabilities/osat" class="hana-cap-card">
                    <div class="hana-cap-card__top">
                        <span class="hana-arrow-reveal" aria-hidden="true">
                            <i data-lucide="arrow-right"
                               style="width:13px; height:13px; color:var(--hana-blue);"></i>
                        </span>
                    </div>
                    <div class="hana-cap-card__icon-area">
                        <img class="hana-cap-icon" src="~/images/icons/osat.png" alt="OSAT" width="88" height="88" />
                    </div>
                    <div class="hana-cap-card__body">
                        <h3 class="hana-cap-card__title">OSAT</h3>
                        <p class="hana-cap-card__desc">
                            Advanced semiconductor assembly and test at the die level, from bare wafer to packaged, qualified parts.
                        </p>
                    </div>
                </a>

                <a href="/capabilities/microelectronic-assembly" class="hana-cap-card">
                    <div class="hana-cap-card__top">
                        <span class="hana-arrow-reveal" aria-hidden="true">
                            <i data-lucide="arrow-right"
                               style="width:13px; height:13px; color:var(--hana-blue);"></i>
                        </span>
                    </div>
                    <div class="hana-cap-card__icon-area">
                        <img class="hana-cap-icon" src="~/images/icons/microelectronic-assembly.png" alt="Microelectronic assembly" width="88" height="88" />
                    </div>
                    <div class="hana-cap-card__body">
                        <h3 class="hana-cap-card__title">Microelectronic Assembly</h3>
                        <p class="hana-cap-card__desc">
                            Precision joining of chips, sensors, MEMS and micro-assembly with micron level tolerance
                        </p>
                    </div>
                </a>

                <a href="/capabilities/automation" class="hana-cap-card">
                    <div class="hana-cap-card__top">
                        <span class="hana-arrow-reveal" aria-hidden="true">
                            <i data-lucide="arrow-right"
                               style="width:13px; height:13px; color:var(--hana-blue);"></i>
                        </span>
                    </div>
                    <div class="hana-cap-card__icon-area">
                        <img class="hana-cap-icon" src="~/images/icons/automation.png" alt="Automation" width="88" height="88" />
                    </div>
                    <div class="hana-cap-card__body">
                        <h3 class="hana-cap-card__title">Automation</h3>
                        <p class="hana-cap-card__desc">
                            Full Inspection, handling, and traceability built into the line for consistent yield at scale.
                        </p>
                    </div>
                </a>

                <a href="/capabilities/dfx-jdm" class="hana-cap-card">
                    <div class="hana-cap-card__top">
                        <span class="hana-arrow-reveal" aria-hidden="true">
                            <i data-lucide="arrow-right"
                               style="width:13px; height:13px; color:var(--hana-blue);"></i>
                        </span>
                    </div>
                    <div class="hana-cap-card__icon-area">
                        <img class="hana-cap-icon" src="~/images/icons/dfx-npi-collaboration.png" alt="DFx and NPI collaboration" width="88" height="88" />
                    </div>
                    <div class="hana-cap-card__body">
                        <h3 class="hana-cap-card__title">DFx &amp; NPI Collaborations</h3>
                        <p class="hana-cap-card__desc">
                            Work along us from design and DFM through first builds to production and on-going improvement.
                        </p>
                    </div>
                </a>

                <a href="/capabilities/rfid-smart-tags" class="hana-cap-card">
                    <div class="hana-cap-card__top">
                        <span class="hana-arrow-reveal" aria-hidden="true">
                            <i data-lucide="arrow-right"
                               style="width:13px; height:13px; color:var(--hana-blue);"></i>
                        </span>
                    </div>
                    <div class="hana-cap-card__icon-area">
                        <img class="hana-cap-icon" src="~/images/icons/rfid-inlay.png" alt="RFID inlay" width="88" height="88" />
                    </div>
                    <div class="hana-cap-card__body">
                        <h3 class="hana-cap-card__title">RFID Inlay</h3>
                        <p class="hana-cap-card__desc">
                            High-volume smart tags and inlays for tire ID, logistics, and retail.
                        </p>
                    </div>
                </a>

                @* OSAT *@

                @* Microelectronics *@

                @* Automation *@

                @* RFID & Smart Tags *@

                @* DFx & JDM Collaboration *@

            </div>@* /track *@

        </div>@* /carousel *@

    </div>
</section>

@* Hide webkit scrollbar on the track *@
<style>
    .hana-carousel__track::-webkit-scrollbar { display: none; }
</style>
