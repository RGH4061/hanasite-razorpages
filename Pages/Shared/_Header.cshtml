                                    <span style="display:flex; flex-direction:column; gap:2px;">
                                        <span class="hana-mega-name" style="font-size:13px; font-weight:600;">Koh Kong</span>
                                        <span style="font-size:11px; color:var(--ink-3);">PCBA &middot; Box Build &middot; EMS</span>
