                    background:#fff; border-top:1px solid var(--line); border-bottom:1px solid var(--line);
                    box-shadow:0 24px 48px rgba(3,10,23,0.12);">
            <div class="hana-wrap" style="padding-top:36px; padding-bottom:40px;">
                <div style="display:grid; grid-template-columns:repeat(6, 1fr); gap:24px;">

                    <div>
                        <a href="/capabilities/pcba-box-build" class="hana-mega-group-heading">PCBA &amp; Box Build</a>
                        <ul style="list-style:none; margin:0; padding:0; display:flex; flex-direction:column; gap:10px;">
                            <li><a href="/capabilities/pcba-box-build/smt-assembly"   class="hana-mega-sub-link">SMT Assembly</a></li>
                            <li><a href="/capabilities/pcba-box-build/cob-assembly"   class="hana-mega-sub-link">COB Assembly</a></li>
                            <li><a href="/capabilities/pcba-box-build/box-build"      class="hana-mega-sub-link">Box Build</a></li>
                        </ul>
                    </div>

                    <div>
                        <a href="/capabilities/osat" class="hana-mega-group-heading">OSAT</a>
                        <ul style="list-style:none; margin:0; padding:0; display:flex; flex-direction:column; gap:10px;">
                            <li><a href="/capabilities/osat/wafer-processing"        class="hana-mega-sub-link">Wafer Processing</a></li>
                            <li><a href="/capabilities/osat/die-attach-wire-bond"    class="hana-mega-sub-link">Die Attach &amp; Wire Bond</a></li>
                            <li><a href="/capabilities/osat/flip-chip"               class="hana-mega-sub-link">Flip Chip</a></li>
                            <li><a href="/capabilities/osat/sip"                     class="hana-mega-sub-link">System in Package (SiP)</a></li>
                            <li><a href="/capabilities/osat/final-test"              class="hana-mega-sub-link">Wafer Probe &amp; Final Test</a></li>
                            <li><a href="/capabilities/osat/wlcsp"                   class="hana-mega-sub-link">Wafer Level Packaging</a></li>
                        </ul>
                    </div>

                    <div>
                        <a href="/capabilities/microelectronic-assembly" class="hana-mega-group-heading">Microelectronic Assembly</a>
                        <ul style="list-style:none; margin:0; padding:0; display:flex; flex-direction:column; gap:10px;">
                            <li><a href="/capabilities/microelectronic-assembly/flip-chip"    class="hana-mega-sub-link">Flip Chip</a></li>
                            <li><a href="/capabilities/microelectronic-assembly/mems"         class="hana-mega-sub-link">MEMS &amp; Sensor Assembly</a></li>
                            <li><a href="/capabilities/microelectronic-assembly/interconnect" class="hana-mega-sub-link">Interconnect Solutions</a></li>
                            <li><a href="/capabilities/microelectronic-assembly/micro"        class="hana-mega-sub-link">Micro-Assembly</a></li>
                        </ul>
                    </div>

                    <div>
                        <a href="/capabilities/rfid-smart-tags" class="hana-mega-group-heading">RFID &amp; Smart Tags</a>
                        <ul style="list-style:none; margin:0; padding:0; display:flex; flex-direction:column; gap:10px;">
                            <li><a href="/capabilities/rfid-smart-tags/tire-tags" class="hana-mega-sub-link">RFID Tire Tags</a></li>
                            <li><a href="/capabilities/rfid-smart-tags/inlays"    class="hana-mega-sub-link">RFID Inlays</a></li>
                        </ul>
                    </div>

                    <div>
                        <a href="/capabilities/automation" class="hana-mega-group-heading">Automation</a>
                        <ul style="list-style:none; margin:0; padding:0; display:flex; flex-direction:column; gap:10px;">
                            <li><a href="/capabilities/automation/aoi-spi"       class="hana-mega-sub-link">In-line AOI &amp; SPI</a></li>
                            <li><a href="/capabilities/automation/robotic"       class="hana-mega-sub-link">Robotic Handling &amp; Test</a></li>
                            <li><a href="/capabilities/automation/mes"           class="hana-mega-sub-link">Manufacturing Traceability</a></li>
                        </ul>
                    </div>

                    <div>
                        <a href="/capabilities/dfx-jdm" class="hana-mega-group-heading">DFx &amp; JDM Collaboration</a>
                        <ul style="list-style:none; margin:0; padding:0; display:flex; flex-direction:column; gap:10px;">
                            <li><a href="/capabilities/dfx-jdm/dfm"  class="hana-mega-sub-link">Design for Excellence (DFx / DFM)</a></li>
                            <li><a href="/capabilities/dfx-jdm/jdm"  class="hana-mega-sub-link">Joint Development Model (JDM)</a></li>
                            <li><a href="/capabilities/dfx-jdm/npi"  class="hana-mega-sub-link">New Product Introduction (NPI)</a></li>
                        </ul>
                    </div>

                </div>
                <div style="margin-top:28px; padding-top:20px; border-top:1px solid var(--line);">
                    <a href="/capabilities" class="hana-link" style="font-size:11px; letter-spacing:0.1em;">
                        All capabilities
                        <i data-lucide="arrow-right" style="width:13px; height:13px;"></i>
                    </a>
                </div>
            </div>
        </div>

        @* Locations *@
        <div data-panel="Locations" class="hana-mega" hidden
             style="position:absolute; top:100%; left:0; right:0; z-index:60;
                    background:#fff; border-top:1px solid var(--line); border-bottom:1px solid var(--line);
                    box-shadow:0 24px 48px rgba(3,10,23,0.12);">
            <div class="hana-wrap"
                 style="padding-top:36px; padding-bottom:40px;
                        display:grid; grid-template-columns:270px 1fr; gap:56px; align-items:start;">
                <div style="border-right:1px solid var(--line); padding-right:40px;">
                    <div style="font-family:var(--font-display); font-size:21px; font-weight:700;
                                letter-spacing:-0.02em; margin-bottom:12px;">Global footprint</div>
                    <p style="font-family:var(--font-text); font-size:13px; line-height:1.6;
                               color:var(--ink-2); margin:0 0 20px; text-wrap:pretty;">
                        Manufacturing across Thailand, Cambodia, China, Korea, and the USA —
                        geographic resilience built in.
                    </p>
                    <a href="/locations" class="hana-link" style="font-size:11px; letter-spacing:0.1em;">
                        All locations
                        <i data-lucide="arrow-right" style="width:13px; height:13px;"></i>
                    </a>
                </div>
                <div style="display:grid; grid-template-columns:1fr 1fr 1fr; column-gap:40px; row-gap:26px;">
                    @* Thailand *@
                    <div>
                        <div style="font-size:13px; font-weight:700; color:var(--ink);
                                    padding-bottom:9px; margin-bottom:4px; border-bottom:1px solid var(--line);">
                            Thailand
                        </div>
                        <ul style="list-style:none; margin:0; padding:0;">
                            <li>
                                <a href="/locations/ayutthaya" class="hana-mega-card"
