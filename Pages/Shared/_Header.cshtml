                                    <span style="color:var(--hana-blue); font-weight:700; font-size:13px; flex-shrink:0;">&rsaquo;</span>
                                    <span style="display:flex; flex-direction:column; gap:2px;">
                                        <span class="hana-mega-name" style="font-size:13px; font-weight:600;">Lamphun</span>
                                        <span style="font-size:11px; color:var(--ink-3);">PCBA &middot; EMS</span>
                                    </span>
                                </a>
                            </li>
                        </ul>
                    </div>
                    @* China + Cambodia *@
                    <div>
                        <div style="font-size:13px; font-weight:700; color:var(--ink);
                                    padding-bottom:9px; margin-bottom:4px; border-bottom:1px solid var(--line);">
                            China
                        </div>
                        <ul style="list-style:none; margin:0; padding:0 0 16px;">
                            <li>
                                <a href="/locations/jiaxing" class="hana-mega-card"
                                   style="display:flex; align-items:baseline; gap:8px; padding:7px 8px;">
                                    <span style="color:var(--hana-blue); font-weight:700; font-size:13px; flex-shrink:0;">&rsaquo;</span>
                                    <span style="display:flex; flex-direction:column; gap:2px;">
                                        <span class="hana-mega-name" style="font-size:13px; font-weight:600;">Jiaxing</span>
                                        <span style="font-size:11px; color:var(--ink-3);">EMS &middot; OSAT &middot; RFID</span>
                                    </span>
                                </a>
                            </li>
                        </ul>
                        <div style="font-size:13px; font-weight:700; color:var(--ink);
                                    padding-bottom:9px; margin-bottom:4px; border-bottom:1px solid var(--line);">
                            Cambodia
                        </div>
                        <ul style="list-style:none; margin:0; padding:0;">
                            <li>
                                <a href="/locations/koh-kong" class="hana-mega-card"
