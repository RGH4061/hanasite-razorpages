@* _Homepage_Hero.cshtml — Circuit canvas hero
   Renders: animated PCB canvas, hero text block, video-stats right panel.

   Requires:
     wwwroot/js/circuit-hero.js   (auto-inits via [data-circuit-hero])
     ~/images/homepage-hero-video-thumb.jpg   (16:9, min 1160×652px)

   Spec ref: design_handoff_homepage/README.md §2
*@

<section class="hana-hero-section"
         style="position:relative; background:#030a17; overflow:hidden; cursor:crosshair; height:550px;"
         aria-label="Homepage hero">

    @* ── Canvas — fills section, JS inits automatically ── *@
    <canvas data-circuit-hero
            style="position:absolute; top:0; left:0; display:block; width:100%; height:100%;"></canvas>

    @* ── Gradient overlays (HTML, not canvas) ────────────── *@
    @* Left text-legibility fade *@
    <div aria-hidden="true"
         style="position:absolute; inset:0; pointer-events:none; z-index:2;
                background:linear-gradient(100deg, rgba(3,10,23,0.55) 0%, rgba(3,10,23,0.28) 44%, transparent 70%);"></div>
    @* Edge vignette *@
    <div aria-hidden="true"
         style="position:absolute; inset:0; pointer-events:none; z-index:3;
                background:radial-gradient(ellipse 95% 85% at 50% 50%, transparent 28%, rgba(3,10,23,0.70) 100%);"></div>
    @* Bottom fade into next section *@
    <div aria-hidden="true"
         style="position:absolute; bottom:0; left:0; right:0; height:80px; z-index:10; pointer-events:none;
                background:linear-gradient(to bottom, transparent, rgba(3,10,23,0.60));"></div>

    @* ── Hero text block ─────────────────────────────────── *@
    <div style="position:absolute; z-index:15; top:50%; left:52px;
                transform:translateY(-50%); max-width:520px; pointer-events:none;">

        @* Badge pill *@
        <div style="display:inline-flex; align-items:center; gap:9px;
                    padding:6px 14px 6px 10px;
                    border:1px solid rgba(18,131,221,0.28); border-radius:999px;
                    background:rgba(18,131,221,0.07);
                    font-family:var(--font-mono); font-size:11px; font-weight:500;
                    color:rgba(78,155,218,0.85); letter-spacing:0.04em;
                    margin-bottom:28px;">
            <span class="hana-blink"
                  style="width:6px; height:6px; border-radius:50%; background:#1283DD; flex-shrink:0;
                         display:inline-block;"></span>
            EMS &middot; OSAT &middot; Microelectronics
        </div>

        @* H1 *@
        <h1 style="font-family:var(--font-display); font-size:58px; font-weight:700;
                   letter-spacing:-0.032em; line-height:1.04; color:#ffffff;
                   margin:0 0 20px; text-wrap:pretty;">
            Electronics Manufacturing<br />That Goes Further.
        </h1>

        @* Subhead *@
        <p style="font-family:var(--font-text); font-size:17px; font-weight:400;
                  line-height:1.6; color:rgba(229,238,245,0.55);
                  margin:0 0 36px; max-width:470px; text-wrap:pretty;">
            A world-class independent electronics manufacturing services (EMS) and
            outsourced semiconductor assembly and test (OSAT) company &mdash; rooted in
            Southeast Asia, operating worldwide.
        </p>

        @* CTAs *@
        <div style="display:flex; gap:12px; pointer-events:auto;">
            <a href="/contact" class="hana-btn hana-btn-primary">
                Talk to engineering
                <i data-lucide="arrow-right" style="width:14px; height:14px;"></i>
            </a>
            <a href="/capabilities"
               class="hana-btn"
               style="background:transparent; color:rgba(255,255,255,0.72);
                      border:1px solid rgba(255,255,255,0.22); border-radius:4px;">
                Our capabilities
            </a>
        </div>

    </div>

    @* ── Right panel — video thumbnail + stats strip ──────── *@
    <aside style="position:absolute; z-index:15; top:50%; right:40px;
                  transform:translateY(-50%); width:660px; pointer-events:auto;"
           aria-label="Company overview">

        @* Autoplay silent hero reel *@
        <div style="position:relative; width:100%; aspect-ratio:16/9;
                    background:#030a17;
                    border:1px solid rgba(18,131,221,0.22);
                    border-radius:10px; overflow:hidden;">

            <video src="~/videos/hero-loop.mp4"
                   poster="~/images/photos/homepage-hero-poster.jpg"
                   autoplay muted loop playsinline preload="metadata"
                   aria-label="Hana manufacturing facility"
                   style="position:absolute; inset:0; width:100%; height:100%; object-fit:cover; display:block;"></video>

        </div>

    </aside>

</section>
