@page "/careers/stories"
@{
    ViewData["Title"] = "Stories — Careers at Hana";
    ViewData["Description"] = "Stories from the people who build microelectronics at Hana.";
}
@section Head {
    <link rel="stylesheet" href="~/css/careers-stories.css" />
}

@* Stories — Careers at Hana. Static content + vanilla interactions in ~/js/careers-stories.js. *@

