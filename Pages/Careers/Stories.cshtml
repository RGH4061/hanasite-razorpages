@page "/careers/stories"
@{
    ViewData["Title"] = "Stories — Careers at Hana";
    ViewData["Description"] = "Stories from the people who build microelectronics at Hana.";
}
@section Head {
    <link rel="stylesheet" href="~/css/careers-stories.css" />
    <style>
      .hero .hero-inner { display: grid; grid-template-columns: 1fr auto; gap: var(--s-7); align-items: center; }
      .hero-card { width: 500px; max-width: 46vw; background: var(--hana-blue-deep, #0E4A7C); border-radius: 14px; overflow: hidden; display: flex; flex-direction: column; }
      .hero-card img { display: block; width: 100%; height: 320px; object-fit: cover; }
      @@media (max-width: 820px) { .hero .hero-inner { grid-template-columns: 1fr; align-items: start; } .hero-card { width: 100%; max-width: none; } }
    </style>
}

@* Stories — Careers at Hana. Static content + vanilla interactions in ~/js/careers-stories.js. *@

