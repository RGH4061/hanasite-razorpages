@page "/careers"
@{
    ViewData["Title"] = "Careers — Hana Microelectronics";
    ViewData["Description"] = "Build microelectronics with Hana — open roles, life at our sites, and how to apply across Thailand, Cambodia and beyond.";
}
@section Head {
    <link rel="stylesheet" href="~/css/careers.css" />
    <style>
      .story-photo { position: relative; overflow: hidden; }
      .story-photo .story-photo-img { position:absolute; inset:0; width:100%; height:100%; object-fit:cover; display:block; }
      .story-photo > svg, .story-photo .photo-label { display:none; }
      .story-photo .zoom-btn { position:absolute; top:12px; right:12px; z-index:3; display:inline-flex; align-items:center; justify-content:center; width:36px; height:36px; border:none; border-radius:8px; cursor:pointer; background: var(--hana-blue, #1283DD); color:#fff; opacity:0; transition:opacity .15s, background .15s; }
      .story-photo:hover .zoom-btn, .story-photo .zoom-btn:focus-visible { opacity:1; }
      .story-photo .zoom-btn:hover { background: var(--hana-blue-deep, #0E4A7C); }
      .story-photo .zoom-btn svg { width:18px; height:18px; }
      .story-lightbox { position:fixed; inset:0; z-index:1000; display:none; align-items:center; justify-content:center; background:rgba(9,30,50,0.92); }
      .story-lightbox.open { display:flex; }
      .story-lightbox img { max-width:min(1100px,92vw); max-height:92vh; width:auto; height:auto; object-fit:contain; border-radius:8px; border:1px solid rgba(255,255,255,0.15); }
      .story-lightbox-close { position:absolute; top:20px; right:24px; display:inline-flex; align-items:center; justify-content:center; width:44px; height:44px; border:none; border-radius:10px; background:rgba(255,255,255,0.14); color:#fff; cursor:pointer; }
      .story-lightbox-close:hover { background:rgba(255,255,255,0.24); }
      .story-lightbox-close svg { width:20px; height:20px; }
    </style>
}

@* Careers landing. Static content + vanilla interactions (tabs, job
   filters, image carousels, topo canvas) in ~/js/careers.js. *@

