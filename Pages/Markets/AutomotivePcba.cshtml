@page "/markets/automotive/automotive-pcba"
@{
    ViewData["Title"] = "Automotive PCBA Assembly | Hana";
    ViewData["Description"] = "Hana assembles automotive PCBAs — body control modules, gateway ECUs and sensor boards — on IATF 16949 lines with AOI and X-ray on every board, across Thailand, China and Cambodia.";
    ViewData["Canonical"] = "https://www.hanagroup.com/markets/automotive/automotive-pcba";

    var activeSlug = "automotive-pcba";
    var subs = new[] {
        new { slug = "power-modules",   name = "Power Modules",   icon = "zap" },
        new { slug = "sensor-assembly", name = "Sensor Assembly", icon = "radio" },
        new { slug = "led-lighting",    name = "LED Lighting",    icon = "lightbulb" },
        new { slug = "rfid-tire-tags",  name = "RFID Tire Tags",  icon = "circle-dot" },
        new { slug = "automotive-pcba", name = "Automotive PCBA", icon = "cpu" }
    };
    var heroStats = new[] {
        new { v = "IATF 16949", l = "QMS" },
        new { v = "Fine-pitch SMT", l = "Process" },
        new { v = "AOI · X-ray", l = "Inspection" },
        new { v = "Board-level", l = "Traceability" }
    };
    var plants = new[] {
        new { route = "lamphun",  country = "Thailand", name = "Lamphun",  note = "PCBA · box build · lighting" },
        new { route = "jiaxing",  country = "China",    name = "Jiaxing",  note = "High-volume PCBA · modules" },
        new { route = "koh-kong", country = "Cambodia", name = "Koh Kong", note = "PCBA · assembly" }
    };
    var faq = new[] {
        new { q = "What quality system do you run for automotive PCBA?", a = "IATF 16949, with PPAP and APQP discipline on new programs. First-article inspection, control plans and reaction plans are standard — not optional add-ons." },
        new { q = "What inspection coverage do you provide?", a = "AOI on every board, X-ray on BGA and area-array packages, and in-circuit or functional test where the customer program requires it. Defect data is logged by board and by reel for traceability." },
        new { q = "Can a program transfer between your PCBA plants?", a = "Yes — the same process is qualified across Thailand, China and Cambodia, so a transfer is a documented first-article qualification, not a re-development. Programs have moved for capacity and supply continuity without rework at the customer end." }
    };
}
@section Head {
    <link rel="stylesheet" href="~/css/automotive.css" />
    <script type="application/ld+json">
    {
      "@@context": "https://schema.org",
      "@@type": "FAQPage",
      "mainEntity": [
        { "@@type": "Question", "name": "What quality system do you run for automotive PCBA?", "acceptedAnswer": { "@@type": "Answer", "text": "IATF 16949, with PPAP and APQP discipline on new programs. First-article inspection, control plans and reaction plans are standard — not optional add-ons." } },
        { "@@type": "Question", "name": "What inspection coverage do you provide?", "acceptedAnswer": { "@@type": "Answer", "text": "AOI on every board, X-ray on BGA and area-array packages, and in-circuit or functional test where the customer program requires it. Defect data is logged by board and by reel for traceability." } },
        { "@@type": "Question", "name": "Can a program transfer between your PCBA plants?", "acceptedAnswer": { "@@type": "Answer", "text": "Yes — the same process is qualified across Thailand, China and Cambodia, so a transfer is a documented first-article qualification, not a re-development. Programs have moved for capacity and supply continuity without rework at the customer end." } }
      ]
    }
    </script>
}

<div class="auto-page">

  <div class="auto-crumb">
    <div class="inner">
      <a href="/markets">Markets</a><span class="sep">›</span>
      <a href="/markets/automotive">Automotive</a><span class="sep">›</span>
      <span class="here">Automotive PCBA</span>
    </div>
  </div>

  <div class="auto-spoke-grid">

    <aside class="auto-side">
      <div class="side-head">Automotive components</div>
      @foreach (var s in subs)
      {
          <a class="s @(s.slug == activeSlug ? "active" : "")" href="/markets/automotive/@s.slug">
              <i data-lucide="@s.icon" style="width:15px;height:15px;@(s.slug == activeSlug ? "" : "color:var(--ink-3);")"></i>
              <span>@s.name</span>
          </a>
      }
      <div class="helper">
        <div class="h">Not sure which fits?</div>
        <p>Tell us what the part does in the vehicle and we'll point you to the right line.</p>
        <a class="cta" href="/contact" style="text-decoration:none;">Talk to engineering <i data-lucide="arrow-right" style="width:12px;height:12px;"></i></a>
      </div>
    </aside>

    <main style="min-width:0; overflow:hidden;">

      <div style="padding:44px 48px 22px;">
        <div style="display:grid; grid-template-columns:minmax(0,1.1fr) minmax(0,0.9fr); gap:40px; align-items:center;">
          <div>
            <div class="auto-eyebrow">Automotive — Automotive PCBA</div>
            <h1 style="font-family:var(--font-display); font-size:40px; font-weight:700; color:var(--ink); line-height:1.06; letter-spacing:-0.03em; margin:0 0 18px; text-wrap:balance;">Automotive PCBA on IATF 16949 qualified lines</h1>
            <p style="font-size:16px; color:var(--ink-2); line-height:1.65; margin:0; text-wrap:pretty;">Body control modules, gateway ECUs, sensor interface boards — Hana assembles automotive electronics on IATF 16949 lines with PPAP and APQP discipline, full traceability, and AOI and X-ray inspection on every board.</p>
          </div>
          <div style="position:relative; overflow:hidden; border-radius:10px; border:1px solid var(--line); background:var(--surface); height:300px; display:flex; align-items:center; justify-content:center; background-image:repeating-linear-gradient(45deg,transparent 0 13px,rgba(18,131,221,0.06) 13px 14px);">
            <span style="font-family:var(--font-mono); font-size:11px; color:var(--ink-3); text-align:center; padding:0 18px; line-height:1.5;">[ Automotive PCBA on an SMT line ]</span>
          </div>
        </div>
      </div>

      <div style="padding:10px 48px;">
        <div class="auto-spec">
          @foreach (var s in heroStats)
          {
              <div class="cell"><div class="l">@s.l</div><div class="v @(s.v.Length > 8 ? "long" : "")">@s.v</div></div>
          }
        </div>
      </div>

      <div style="padding:20px 48px;">
        <div class="auto-sechead">
          <h2>The capability behind automotive pcba</h2>
          <p>The sub-market page frames the application. The capability page carries the process depth.</p>
        </div>
        <div style="border:1px solid var(--line); border-radius:var(--radius-card); background:#fff; padding:28px 30px;">
          <div style="font-size:10px; font-weight:700; letter-spacing:0.1em; text-transform:uppercase; color:var(--ink-3); margin-bottom:10px;">The capability behind it</div>
          <h3 style="font-family:var(--font-display); font-size:21px; font-weight:600; color:var(--ink); line-height:1.2; letter-spacing:-0.01em; margin:0 0 12px;">Built on Hana's PCBA &amp; Box Build capability</h3>
          <p style="font-size:14px; color:var(--ink-2); line-height:1.65; margin:0 0 20px; max-width:560px;">Automotive PCBA is built on the same SMT, inspection and test processes Hana runs across its board assembly lines — with IATF 16949 discipline, PPAP documentation and full material traceability layered in.</p>
          <a href="/capabilities/pcba-box-build" style="font-size:11px; font-weight:700; letter-spacing:0.08em; text-transform:uppercase; color:var(--hana-blue); text-decoration:none; display:inline-flex; align-items:center; gap:6px;">See PCBA &amp; Box Build <i data-lucide="arrow-right" style="width:12px;height:12px;"></i></a>
        </div>
      </div>

      <div style="background:#071f35; border-top:1px solid var(--line); padding:40px 48px;">
        <div class="auto-sechead on-dark">
          <h2>Where we build it</h2>
          <p>Automotive PCBA runs across Thailand, China and Cambodia — the same process qualified across three plants for supply resilience.</p>
        </div>
        <div class="auto-plants" style="grid-template-columns:repeat(@plants.Length, 1fr);">
          @foreach (var p in plants)
          {
              <a class="auto-plantcard" href="/locations/@p.route" style="text-decoration:none; color:inherit;">
                  <div>
                      <span class="co"><i data-lucide="map-pin" style="width:13px;height:13px;"></i> @p.country</span>
                      <div class="nm">@p.name</div>
                      <div class="note">@p.note</div>
                  </div>
                  <span class="cta">View plant <i data-lucide="arrow-right" style="width:12px;height:12px;"></i></span>
              </a>
          }
        </div>
        <p style="font-size:13px; color:rgba(255,255,255,0.5); line-height:1.5; margin:18px 0 0;"><a href="/locations" style="color:rgba(255,255,255,0.75); text-decoration:none; font-weight:600;">View all locations →</a></p>
      </div>

      <div style="background:var(--bg); border-top:1px solid var(--line); padding:40px 48px 48px;">
        <div class="auto-sechead"><h2>Frequently asked questions</h2></div>
        <div class="auto-faq">
          @for (var i = 0; i < faq.Length; i++)
          {
              var f = faq[i];
              <div class="item @(i == 0 ? "is-open" : "")">
                  <button type="button" class="q">
                      <span class="num">@($"0{i + 1}")</span>
                      <h3 class="qt">@f.q</h3>
                      <span class="chev"><i data-lucide="chevron-down" style="width:16px;height:16px;"></i></span>
                  </button>
                  <div class="panel"><span></span><p>@f.a</p></div>
              </div>
          }
        </div>
        <div style="margin-top:22px; padding-top:18px; border-top:1px solid var(--line);">
          <a href="/markets/automotive" style="font-size:12px; font-weight:700; letter-spacing:0.07em; text-transform:uppercase; color:var(--hana-blue); text-decoration:none; display:inline-flex; align-items:center; gap:6px;"><i data-lucide="arrow-right" style="width:13px;height:13px;"></i> Back to the Automotive market hub</a>
        </div>
      </div>

    </main>
  </div>

  <section class="auto-cta" data-hana-bg="flow" data-variant="dark" data-accent="cyan" data-fade="none">
    <div class="inner">
      <div>
        <h2>Have an automotive board to build?</h2>
        <p>Send a BOM and target volumes. We'll come back with a DFM read and an indicative plan.</p>
      </div>
      <div class="actions">
        <a href="/contact" class="auto-btn auto-btn--ondark-primary">Start a quote <i data-lucide="arrow-right" style="width:13px;height:13px;"></i></a>
        <a href="/contact" class="auto-btn auto-btn--ondark-secondary">Talk to an engineer</a>
      </div>
    </div>
  </section>

</div>

@section Scripts {
    <script src="~/js/automotive.js"></script>
}
