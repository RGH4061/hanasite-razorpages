@page "/markets/automotive/led-lighting"
@{
    ViewData["Title"] = "Automotive LED Lighting Assembly | Hana";
    ViewData["Description"] = "Hana assembles LED modules and driver boards for automotive headlamps, signaling and interior lighting — thermal-path engineered, on AEC-Q-qualified COB and SMT lines in Thailand.";
    ViewData["Canonical"] = "https://www.hanagroup.com/markets/automotive/led-lighting";

    var activeSlug = "led-lighting";
    var subs = new[] {
        new { slug = "power-modules",   name = "Power Modules",   icon = "zap" },
        new { slug = "sensor-assembly", name = "Sensor Assembly", icon = "radio" },
        new { slug = "led-lighting",    name = "LED Lighting",    icon = "lightbulb" },
        new { slug = "rfid-tire-tags",  name = "RFID Tire Tags",  icon = "circle-dot" },
        new { slug = "automotive-pcba", name = "Automotive PCBA", icon = "cpu" }
    };
    var heroStats = new[] {
        new { v = "Headlamp · DRL · Signal", l = "Applications" },
        new { v = "Thermal-managed", l = "Design-in" },
        new { v = "COB · SMT", l = "Process" },
        new { v = "AEC-Q", l = "Qualified" }
    };
    var plants = new[] {
        new { route = "ayutthaya", country = "Thailand", name = "Ayutthaya", note = "Power modules · microelectronics" },
        new { route = "lamphun",   country = "Thailand", name = "Lamphun",   note = "PCBA · box build · lighting" }
    };
    var faq = new[] {
        new { q = "What LED applications does Hana assemble for?", a = "Headlamps, daytime running lights, turn and brake signals, and interior ambient lighting — including matrix and adaptive headlamp modules that combine multiple LED clusters with a driver board." },
        new { q = "How is the thermal path handled?", a = "Thermal interface material, substrate, and heatsink attach are specified alongside the LED die selection — so junction temperature stays within rating over the product lifetime, not just at first power-on." },
        new { q = "Do you support the full module, or only the LED array?", a = "Both. Hana assembles the LED array (COB or SMT), the driver PCB, and the integrated module — with box-build capability to complete the housing assembly in the same facility." }
    };
}
@section Head {
    <link rel="stylesheet" href="~/css/automotive.css" />
    <script type="application/ld+json">
    {
      "@@context": "https://schema.org",
      "@@type": "FAQPage",
      "mainEntity": [
        { "@@type": "Question", "name": "What LED applications does Hana assemble for?", "acceptedAnswer": { "@@type": "Answer", "text": "Headlamps, daytime running lights, turn and brake signals, and interior ambient lighting — including matrix and adaptive headlamp modules that combine multiple LED clusters with a driver board." } },
        { "@@type": "Question", "name": "How is the thermal path handled?", "acceptedAnswer": { "@@type": "Answer", "text": "Thermal interface material, substrate, and heatsink attach are specified alongside the LED die selection — so junction temperature stays within rating over the product lifetime, not just at first power-on." } },
        { "@@type": "Question", "name": "Do you support the full module, or only the LED array?", "acceptedAnswer": { "@@type": "Answer", "text": "Both. Hana assembles the LED array (COB or SMT), the driver PCB, and the integrated module — with box-build capability to complete the housing assembly in the same facility." } }
      ]
    }
    </script>
}

<div class="auto-page">

  <div class="auto-crumb">
    <div class="inner">
      <a href="/markets">Markets</a><span class="sep">›</span>
      <a href="/markets/automotive">Automotive</a><span class="sep">›</span>
      <span class="here">LED Lighting</span>
    </div>
  </div>

  <div class="auto-spoke-grid">

    <aside class="auto-side">
      <div class="side-head">Automotive sub-markets</div>
      @foreach (var s in subs)
      {
          <a class="s @(s.slug == activeSlug ? "active" : "")" href="/markets/automotive/@s.slug">
              <i data-lucide="@s.icon" style="width:15px;height:15px;@(s.slug == activeSlug ? "" : "color:var(--ink-3);")"></i>
              <span>@s.name</span>
          </a>
      }
      <div class="helper">
        <div class="h">Not sure which fits?</div>
        <p>Tell us what the part does in the vehicle and we'll point you to the right line.</p>
        <a class="cta" href="/contact" style="text-decoration:none;">Talk to engineering <i data-lucide="arrow-right" style="width:12px;height:12px;"></i></a>
      </div>
    </aside>

    <main style="min-width:0; overflow:hidden;">

      <div style="padding:44px 48px 22px;">
        <div style="display:grid; grid-template-columns:minmax(0,1.1fr) minmax(0,0.9fr); gap:40px; align-items:center;">
          <div>
            <div class="auto-eyebrow">Automotive — LED Lighting</div>
            <h1 style="font-family:var(--font-display); font-size:40px; font-weight:700; color:var(--ink); line-height:1.06; letter-spacing:-0.03em; margin:0 0 18px; text-wrap:balance;">LED module and driver assembly for automotive lighting</h1>
            <p style="font-size:16px; color:var(--ink-2); line-height:1.65; margin:0; text-wrap:pretty;">Headlamps, daytime running lights, turn signals and interior lighting — Hana assembles LED modules and driver boards for the full lighting stack. The thermal path is designed in from the start, so lumens and lifetime hold under the hood.</p>
          </div>
          <div style="position:relative; overflow:hidden; border-radius:10px; border:1px solid var(--line); background:var(--surface); height:300px; display:flex; align-items:center; justify-content:center; background-image:repeating-linear-gradient(45deg,transparent 0 13px,rgba(18,131,221,0.06) 13px 14px);">
            <span style="font-family:var(--font-mono); font-size:11px; color:var(--ink-3); text-align:center; padding:0 18px; line-height:1.5;">[ LED headlamp module on the assembly line ]</span>
          </div>
        </div>
      </div>

      <div style="padding:10px 48px;">
        <div class="auto-spec">
          @foreach (var s in heroStats)
          {
              <div class="cell"><div class="l">@s.l</div><div class="v @(s.v.Length > 8 ? "long" : "")">@s.v</div></div>
          }
        </div>
      </div>

      <div style="padding:20px 48px;">
        <div class="auto-sechead">
          <h2>The capability behind led lighting</h2>
          <p>The sub-market page frames the application. The capability page carries the process depth.</p>
        </div>
        <div style="border:1px solid var(--line); border-radius:var(--radius-card); background:#fff; padding:28px 30px;">
          <div style="font-size:10px; font-weight:700; letter-spacing:0.1em; text-transform:uppercase; color:var(--ink-3); margin-bottom:10px;">The capability behind it</div>
          <h3 style="font-family:var(--font-display); font-size:21px; font-weight:600; color:var(--ink); line-height:1.2; letter-spacing:-0.01em; margin:0 0 12px;">Built on Hana's Microelectronic Assembly</h3>
          <p style="font-size:14px; color:var(--ink-2); line-height:1.65; margin:0 0 20px; max-width:560px;">LED module assembly uses the same COB die-attach, wire bonding and encapsulation processes Hana runs for microelectronics — with thermal interface design layered in for the automotive lighting environment.</p>
          <a href="/capabilities/microelectronic-assembly" style="font-size:11px; font-weight:700; letter-spacing:0.08em; text-transform:uppercase; color:var(--hana-blue); text-decoration:none; display:inline-flex; align-items:center; gap:6px;">See Microelectronic Assembly <i data-lucide="arrow-right" style="width:12px;height:12px;"></i></a>
        </div>
      </div>

      <div style="background:#071f35; border-top:1px solid var(--line); padding:40px 48px;">
        <div class="auto-sechead on-dark">
          <h2>Where we build it</h2>
          <p>LED lighting assembly runs in Thailand, combining COB and SMT capability across two plants.</p>
        </div>
        <div class="auto-plants" style="grid-template-columns:repeat(@plants.Length, 1fr);">
          @foreach (var p in plants)
          {
              <a class="auto-plantcard" href="/locations/@p.route" style="text-decoration:none; color:inherit;">
                  <div>
                      <span class="co"><i data-lucide="map-pin" style="width:13px;height:13px;"></i> @p.country</span>
                      <div class="nm">@p.name</div>
                      <div class="note">@p.note</div>
                  </div>
                  <span class="cta">View plant <i data-lucide="arrow-right" style="width:12px;height:12px;"></i></span>
              </a>
          }
        </div>
        <p style="font-size:13px; color:rgba(255,255,255,0.5); line-height:1.5; margin:18px 0 0;"><a href="/locations" style="color:rgba(255,255,255,0.75); text-decoration:none; font-weight:600;">View all locations →</a></p>
      </div>

      <div style="background:var(--bg); border-top:1px solid var(--line); padding:40px 48px 48px;">
        <div class="auto-sechead"><h2>Frequently asked questions</h2></div>
        <div class="auto-faq">
          @for (var i = 0; i < faq.Length; i++)
          {
              var f = faq[i];
              <div class="item @(i == 0 ? "is-open" : "")">
                  <button type="button" class="q">
                      <span class="num">@($"0{i + 1}")</span>
                      <h3 class="qt">@f.q</h3>
                      <span class="chev"><i data-lucide="chevron-down" style="width:16px;height:16px;"></i></span>
                  </button>
                  <div class="panel"><span></span><p>@f.a</p></div>
              </div>
          }
        </div>
        <div style="margin-top:22px; padding-top:18px; border-top:1px solid var(--line);">
          <a href="/markets/automotive" style="font-size:12px; font-weight:700; letter-spacing:0.07em; text-transform:uppercase; color:var(--hana-blue); text-decoration:none; display:inline-flex; align-items:center; gap:6px;"><i data-lucide="arrow-right" style="width:13px;height:13px;"></i> Back to the Automotive market hub</a>
        </div>
      </div>

    </main>
  </div>

  <section class="auto-cta" data-hana-bg="flow" data-variant="dark" data-accent="cyan" data-fade="none">
    <div class="inner">
      <div>
        <h2>Have a lighting module to build?</h2>
        <p>Send the optical and driver spec. We'll come back with a thermal-path view and an indicative plan.</p>
      </div>
      <div class="actions">
        <a href="/contact" class="auto-btn auto-btn--ondark-primary">Start a quote <i data-lucide="arrow-right" style="width:13px;height:13px;"></i></a>
        <a href="/contact" class="auto-btn auto-btn--ondark-secondary">Talk to an engineer</a>
      </div>
    </div>
  </section>

</div>

@section Scripts {
    <script src="~/js/automotive.js"></script>
}
