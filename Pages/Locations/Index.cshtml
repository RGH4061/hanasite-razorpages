@page
@{
    ViewData["Title"] = "Locations — global footprint";
    ViewData["Description"] = "Hana manufactures across Thailand, Cambodia, China, South Korea, and the USA — one group, one quality system.";
}

@* ============================================================
   Locations hub. Static content; the world map is progressively
   enhanced by ~/js/locations-map.js. Section backgrounds render
   via ~/js/hana-backgrounds.js ([data-hana-bg]).
   ============================================================ *@

<style>
  .lc-plant-card:hover{ border-color:color-mix(in srgb, #0E4A7C 55%, var(--line)) !important; box-shadow:0 8px 24px -12px rgba(18,131,221,.28); transform:translateY(-2px); }
  .lc-card-link:hover{ opacity:.78; }
  @media (max-width:767px){
    .lc-intro{ padding:36px 20px 22px !important; }
    .lc-hub-h1{ font-size:34px !important; }
    .lc-hub-sub{ font-size:18px !important; }
    .lc-map-block{ display:none !important; }
    .lc-adv-inner{ padding:44px 20px !important; }
    .lc-adv-grid{ grid-template-columns:1fr !important; }
    .lc-plants-inner{ padding:36px 20px 44px !important; }
    .lc-plants-head{ flex-direction:column !important; gap:14px !important; margin-bottom:24px !important; }
    .lc-country-grid{ grid-template-columns:1fr !important; }
    .lc-country-pair{ grid-template-columns:1fr !important; gap:36px !important; }
  }
</style>

<div style="border-bottom:1px solid var(--line);background:var(--bg);">
  <div style="max-width:1240px;margin:0 auto;padding:11px 20px;font-size:12.5px;color:var(--ink-3);display:flex;gap:8px;align-items:center;font-family:var(--font-text);flex-wrap:wrap;">
    <a href="/" class="hana-link" style="font-size:12.5px;">Home</a>
    <span style="color:var(--line);">&rsaquo;</span>
    <span style="color:var(--ink);font-weight:600;">Locations</span>
  </div>
</div>

<div class="lc-intro" style="max-width:1240px;margin:0 auto;padding:62px 32px 30px;">
  <div class="hana-spec-label" style="color:#0E4A7C;margin-bottom:16px;">Locations</div>
  <h1 class="lc-hub-h1" style="font-family:var(--font-display);font-size:50px;font-weight:700;letter-spacing:-0.03em;line-height:1.04;color:var(--ink);margin:0 0 20px;max-width:820px;">Our global footprint</h1>
  <p class="lc-hub-sub" style="font-family:var(--font-display);font-size:26px;font-weight:600;letter-spacing:-0.02em;line-height:1.32;color:var(--ink-2);max-width:760px;margin:0;text-wrap:balance;">One group, one quality system, across five countries &mdash; so consistent quality and responsive service scale wherever you choose to build.</p>
</div>

<div class="lc-map-block" style="max-width:1240px;margin:0 auto;padding:0 32px 20px;">
  <div id="lc-worldmap"></div>
  <script id="lc-map-data" type="application/json">[{"slug":"ayutthaya","city":"Ayutthaya","country":"Thailand","summary":"Advanced OSAT and IC manufacturing under Hana IP.","url":"/locations/ayutthaya","status":"internal"},{"slug":"lamphun","city":"Lamphun","country":"Thailand","summary":"EMS and PCBA to box build assembly across microelectronics and more.","url":"/locations/lamphun","status":"internal"},{"slug":"jiaxing","city":"Jiaxing","country":"China","summary":"Vertically integrated OSAT to EMS and box build production. Specializing in complex wafer, SiC power module and industrial IoT production lines.","url":"/locations/jiaxing","status":"internal"},{"slug":"ohio","city":"Solon, Ohio","country":"USA","summary":"A world leader in RFID design and tire tag inlay production with microdisplay and precision camera module capabilities. A domestic US EMS option.","url":"/locations/ohio","linkLabel":"View Hana USA site","status":"internal"},{"slug":"koh-kong","city":"Koh Kong","country":"Cambodia","summary":"Expert in manual assembly for labor-intensive products, specializing in EMS and PCBA services.","url":"/locations/koh-kong","status":"internal"},{"slug":"cheongju","city":"Cheongju","country":"South Korea","summary":"Silicon-carbide power modules for EV and industrial, designed under Powermaster Semiconductor.","url":"/locations/cheongju","linkLabel":"View Cheongju site","status":"affiliate"}]</script>
</div>

