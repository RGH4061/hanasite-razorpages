@page "/locations/koh-kong"
@{
    ViewData["Title"] = "Koh Kong plant";
    ViewData["Description"] = "A TAA-compliant EMS base in the Koh Kong SEZ";
}

@section Head {
    <link rel="stylesheet" href="~/css/locations-mobile.css" />
}

@* ============================================================
   Koh Kong plant page (Cambodia).
   Static content — no JS framework. Section backgrounds render
   via ~/js/hana-backgrounds.js ([data-hana-bg]); the capability
   and product carousels are wired by ~/js/locations.js.
   ============================================================ *@

<style>
  .cg-section > .hana-bg-layer { opacity: .55 !important; }
  .cg-card { transition: transform 160ms ease, box-shadow 160ms ease; }
  .cg-card:hover { transform: translateY(-3px); box-shadow: 0 12px 30px rgba(3,10,23,0.32); }
  .cg-title:hover { color: var(--hana-blue) !important; }
  .cg-link:hover { color: var(--hana-blue) !important; }
  .cg-link:hover .cg-arr { transform: translateX(3px); }
  .cg-nav:hover:not(:disabled) { filter: brightness(1.08); }
  .lc-prod-nav:hover:not(:disabled) { border-color: var(--hana-blue) !important; color: var(--hana-blue) !important; }
  .cg-scroll, .lc-prod-scroll { scrollbar-width: none; -ms-overflow-style: none; }
  .cg-scroll::-webkit-scrollbar, .lc-prod-scroll::-webkit-scrollbar { display: none; }
</style>

<div style="border-bottom:1px solid var(--line);background:var(--bg);">
  <div style="max-width:1240px;margin:0 auto;padding:11px 20px;font-size:12.5px;color:var(--ink-3);display:flex;gap:8px;align-items:center;font-family:var(--font-text);flex-wrap:wrap;">
    <a href="/locations" class="hana-link" style="font-size:12.5px;">Locations</a>
    <span style="color:var(--line);">&rsaquo;</span>
    <span style="color:var(--ink-3);">Cambodia</span>
    <span style="color:var(--line);">&rsaquo;</span>
    <span style="color:var(--ink);font-weight:600;">Koh Kong</span>
  </div>
</div>

<div class="lc-hero-veil" style="position:relative;height:440px;overflow:hidden;background:#030a17;">
  <img src="~/images/koh-kong-facility.jpg" alt="Koh Kong · Cambodia" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center;" />
  <div class="lc-hero-tex" data-hana-bg="wafer" data-variant="dark" data-accent="cyan" data-fade="none" style="position:absolute;top:0;bottom:0;left:0;width:54%;-webkit-mask-image:linear-gradient(to right,#000 35%,transparent 100%);mask-image:linear-gradient(to right,#000 35%,transparent 100%);opacity:.85;"></div>
  <div style="position:absolute;inset:0;background:linear-gradient(to right,rgba(3,10,23,0.94) 0%,rgba(3,10,23,0.78) 30%,rgba(3,10,23,0.32) 52%,rgba(3,10,23,0) 72%);"></div>
  <div style="position:absolute;inset:0;">
    <div style="max-width:1240px;margin:0 auto;padding:0 32px;height:100%;display:flex;flex-direction:column;justify-content:center;">
      <div style="max-width:460px;">
        <div style="color:#7EC8FF;font-family:var(--font-text);font-size:10px;font-weight:700;letter-spacing:0.16em;text-transform:uppercase;margin-bottom:14px;">Cambodia · Koh Kong</div>
        <h1 style="font-family:var(--font-display);font-size:60px;font-weight:700;letter-spacing:-0.03em;line-height:0.98;color:#fff;margin:0 0 18px;">Koh Kong</h1>
        <p style="font-size:18px;line-height:1.55;color:rgba(255,255,255,0.85);margin:0;">A TAA-compliant EMS base in the Koh Kong SEZ — manufacturing here qualifies for US federal and government supply. PCBA, final assembly, box build and micro-assembly, from medical devices to consumer electronics, two kilometres from the Thai border.</p>
      </div>
    </div>
  </div>
  <div style="position:absolute;right:16px;bottom:12px;font-family:var(--font-mono);font-size:10px;letter-spacing:0.04em;color:rgba(255,255,255,0.9);text-shadow:0 1px 5px rgba(0,0,0,0.7);text-transform:uppercase;">Koh Kong · Cambodia</div>
</div>

<section style="background:linear-gradient(to right,rgba(14,74,124,0.11) 0%,rgba(14,74,124,0.04) 30%,rgba(245,247,250,0) 62%),var(--bg);border-bottom:1px solid var(--line);">
