@page "/about/history"
@{
    ViewData["Title"] = "Our heritage — Hana Microelectronics";
    ViewData["Description"] = "Building microelectronics since 1978 — the history of Hana Microelectronics across five countries.";
}
@section Head {
    <link rel="stylesheet" href="~/css/about-history.css" />
}

@* Our heritage. Static content + interactive decade timeline
   (~/js/about-heritage.js). Page CSS in ~/css/about-history.css. *@

<!-- ── Heritage flow wrapper: hero + decade bar + timeline share one flow field ── -->
<div class="heritage-flow" data-hana-bg="flow" data-variant="light" data-accent="cyan" data-fade="none">

<!-- ── Hero band: breadcrumb + hero ── -->
<div class="hero-band hero-band--flow">
  <div class="subbar">
    <div class="subbar-inner">
      <nav class="crumbs" aria-label="Breadcrumb">
        <a href="/">Home</a><span class="sep">/</span>
        <span class="nolink">About</span><span class="sep">/</span>
        <span>Our Heritage</span>
      </nav>
      <div class="meta">EST. 1978 · BANGKOK</div>
    </div>
  </div>

  <section class="hero">
    <div class="hero-inner">
      <div class="hero-figure" aria-label="1978 to 2026">
        <span class="year">1978</span>
        <span class="arrow" aria-hidden="true"></span>
        <span class="year year-now">2026</span>
      </div>
      <p class="hero-summary">From a workshop in Bangkok to operations across the globe. Follow our story and growth from humble beginnings assembling watch modules to a leading electronics manufacturing operation. </p>
      <div class="hero-cta">
        <a href="#" class="hana-btn hana-btn-primary">Explore our capabilities</a>
        <a href="#" class="hana-btn hana-btn-secondary">EXPLORE OUR LOCATIONS</a>
      </div>
    </div>
  </section>
</div>

<!-- ── Decade nav (shares the hero's flow field via .heritage-flow) ── -->
<div class="decade-stick-sentinel" aria-hidden="true" style="height:1px;"></div>
<nav class="decade-nav">
  <div class="decade-nav-inner">
    <button class="decade-chip is-active" data-decade="1970s">1970s</button>
    <button class="decade-chip" data-decade="1980s">1980s</button>
    <button class="decade-chip" data-decade="1990s">1990s</button>
    <button class="decade-chip" data-decade="2000s">2000s</button>
    <button class="decade-chip" data-decade="2010s">2010s</button>
    <button class="decade-chip" data-decade="2020s">2020s</button>
  </div>
</nav>

<!-- ── Horizontal timeline ── -->
<section class="timeline-h-section">
  <button class="nav-btn nav-prev" aria-label="Previous event">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <polyline points="15 18 9 12 15 6"></polyline>
    </svg>
  </button>

  <div class="timeline-h" id="timeline">
    <div class="timeline-track">

      <div class="decade-marker" aria-hidden="true"><span>1970s</span></div>

      <article class="t-slot" data-decade="1970s" data-year="1978">
        <div class="t-card">
          <span class="t-year">1978</span>
          <h3 class="t-headline">A wooden house on Silom Road</h3>
          <p class="t-body">Founded in Bangkok as Minerva Trading Co., Ltd. —
            thirty people assembling LED watch modules in a wooden house at
            Silom, Bangrak. Later renamed Minerva Electronics, then Hana
            Industries.</p>
        </div>
      </article>

      <article class="t-slot" data-decade="1970s" data-year="1979">
        <div class="t-card">
          <span class="t-year">1979</span>
          <h3 class="t-headline">Onto LCD watch modules</h3>
          <p class="t-body">The workshop moved into LCD (liquid crystal display)
            watch module assembly, following the next wave of consumer
            electronics components.</p>
        </div>
      </article>

      <div class="decade-marker" aria-hidden="true"><span>1980s</span></div>

      <article class="t-slot" data-decade="1980s" data-year="1982">
        <div class="t-card">
          <span class="t-year">1982</span>
          <h3 class="t-headline">A factory for Swiss watchmaking</h3>
          <p class="t-body">A new factory opened on Ngang-Linchi Road to
            assemble electronic modules for quartz analog watch movements,
            supplying a major Swiss watch group.</p>
        </div>
      </article>

      <article class="t-slot" data-decade="1980s" data-year="1983">
        <div class="t-card">
          <span class="t-year">1983</span>
          <h3 class="t-headline">Complete watch movements</h3>
          <p class="t-body">Production expanded from modules to complete watch
            movements, distributed into the Hong Kong watch market.</p>
        </div>
      </article>

      <article class="t-slot" data-decade="1980s" data-year="1984">
        <div class="t-card">
          <span class="t-year">1984</span>
          <h3 class="t-headline">First step into semiconductors</h3>
          <p class="t-body">Hana Semiconductor (BKK) Co., Ltd. was established
            — the first move into integrated circuit (IC) assembly and a
            deliberate step into higher-technology manufacturing.</p>
        </div>
      </article>

      <article class="t-slot" data-decade="1980s" data-year="1986">
        <div class="t-card">
          <span class="t-year">1986</span>
          <h3 class="t-headline">Expansion at Laksi</h3>
          <p class="t-body">PCBA and quartz watch production moved from
            Ngang-Linchi to Laksi to make room for growing IC work. Hana Coil
            Co., Ltd. was established to manufacture coil winding.</p>
        </div>
      </article>

      <article class="t-slot" data-decade="1980s" data-year="1988">
        <div class="t-card">
          <span class="t-year">1988</span>
          <h3 class="t-headline">A new name, a clearer focus</h3>
          <p class="t-body">"Hana Industries" became "Hana Microelectronics Co.,
            Ltd." Coil winding moved from Laksi to Suthisarn. PCBA production
            started at the Laksi plant.</p>
        </div>
      </article>

      <article class="t-slot" data-decade="1980s" data-year="1989">
        <div class="t-card">
          <span class="t-year">1989</span>
          <h3 class="t-headline">A trading subsidiary</h3>
          <p class="t-body">Hana Trading Co., Ltd. was established to import
            finished watches from Hong Kong.</p>
        </div>
      </article>

      <div class="decade-marker" aria-hidden="true"><span>1990s</span></div>

      <article class="t-slot" data-decade="1990s" data-year="1991">
        <div class="t-card">
          <span class="t-year">1991</span>
          <h3 class="t-headline">Consolidating in Laksi</h3>
          <p class="t-body">Integrated circuit production moved from
            Ngang-Linchi to the Laksi plant, bringing semiconductor work onto a
            single site. The following year, the headquarters moved from Silom
            to Laksi as the business expanded into functional test &mdash; and
            Laksi has been Hana&rsquo;s home ever since.</p>
        </div>
      </article>

      <article class="t-slot" data-decade="1990s" data-year="1993">
        <div class="t-card">
          <span class="t-year">1993</span>
          <h3 class="t-headline">Lamphun, and a public listing</h3>
          <p class="t-body">PCBA, COB, and coil winding moved to a new facility
            in the Northern Region Industrial Estate in Lamphun, and Hana
            listed on the Stock Exchange of Thailand as Hana Microelectronics
            Public Co., Ltd. PCBA production began at the new site the
            following year.</p>
        </div>
      </article>

      <article class="t-slot" data-decade="1990s" data-year="1996">
        <div class="t-card">
          <span class="t-year">1996</span>
          <h3 class="t-headline">Hana Technologies, and a Shanghai subsidiary</h3>
          <p class="t-body">Acquired 100% of Swire Technologies Ltd. (renamed
            Hana Technologies). Hana Microelectronics Co., Ltd. (Shanghai) was
            established — the first manufacturing presence in China.</p>
        </div>
      </article>

      <article class="t-slot" data-decade="1990s" data-year="1997">
        <div class="t-card">
          <span class="t-year">1997</span>
          <h3 class="t-headline">A fire, and a new IC plant in Ayutthaya</h3>
          <p class="t-body">A fire at the Bangkok semiconductor plant caused
            approximately THB 300 million in damage. IC production relocated to
            the Hi-Tech Industrial Estate in Bang Pa-In, Ayutthaya — still home
            to Hana's OSAT operations today.</p>
        </div>
      </article>

      <article class="t-slot" data-decade="1990s" data-year="1998">
        <div class="t-card">
          <span class="t-year">1998</span>
          <h3 class="t-headline">Olin Interconnect Technologies acquisition</h3>
          <p class="t-body">Acquired 100% of Olin Interconnect Technologies (a
            division of Olin Corporation, US), forming a new subsidiary:
            Advanced Interconnect Technologies (AIT).</p>
        </div>
      </article>

      <article class="t-slot" data-decade="1990s" data-year="1999">
        <div class="t-card">
          <span class="t-year">1999</span>
          <h3 class="t-headline">AIT merger, and a step into microdisplays</h3>
          <p class="t-body">Hana Technologies merged with AIT, an IC
            manufacturer in Batam, Indonesia, for a 43% stake. Hana Microdisplay
            Technologies, Inc. was established in the US to manufacture LCoS
            components.</p>
        </div>
      </article>

      <div class="decade-marker" aria-hidden="true"><span>2000s</span></div>

      <article class="t-slot" data-decade="2000s" data-year="2003">
        <div class="t-card">
          <span class="t-year">2003</span>
          <h3 class="t-headline">A second China subsidiary, in Jiaxing</h3>
          <p class="t-body">Hana Microelectronics Co., Ltd. (Jiaxing) was
            established in China&rsquo;s Yangtze River Delta, around 100 km
            southwest of Shanghai &mdash; the group&rsquo;s second China
            presence after Shanghai.</p>
        </div>
      </article>

      <article class="t-slot" data-decade="2000s" data-year="2005">
        <div class="t-card">
          <span class="t-year">2005</span>
          <h3 class="t-headline">Jiaxing, China &mdash; operations begin</h3>
          <p class="t-body">Production began at the Jiaxing site in eastern
            China, with PCBA and integrated circuits as the lead products.</p>
        </div>
      </article>

      <article class="t-slot" data-decade="2000s" data-year="2007">
        <div class="t-card">
          <span class="t-year">2007</span>
          <h3 class="t-headline">Lamphun and Ayutthaya grow; AIT sold</h3>
          <p class="t-body">Lamphun added a 10,000 m² building — a 60% floor
            space increase. Ayutthaya added 3,000 m² of capacity. AIT was sold
            to Unisem.</p>
        </div>
      </article>

      <div class="decade-marker" aria-hidden="true"><span>2010s</span></div>

      <article class="t-slot" data-decade="2010s" data-year="2011">
        <div class="t-card">
          <span class="t-year">2011</span>
          <h3 class="t-headline">Floods in Thailand</h3>
          <p class="t-body">The Ayutthaya subsidiary was inundated by
            Thailand's flooding in early October — causing significant property
            damage and business interruption. The team rebuilt.</p>
        </div>
      </article>

      <article class="t-slot" data-decade="2010s" data-year="2013">
        <div class="t-card">
          <span class="t-year">2013</span>
          <h3 class="t-headline">A new subsidiary in Cambodia</h3>
          <p class="t-body">Hana Microelectronics (Cambodia) Co., Ltd. was
            established at the Koh Kong Special Economic Zone — the beginning
            of a third manufacturing country for the group.</p>
        </div>
      </article>

      <article class="t-slot" data-decade="2010s" data-year="2014">
        <div class="t-card">
          <span class="t-year">2014</span>
          <h3 class="t-headline">Recovery, a new HQ, and Lamphun 2</h3>
          <p class="t-body">The headquarters moved to a new site at
            Vibhavadi-Rangsit, Bangkok, on land owned by the company. Final
            flood insurance settlement was received. A second Lamphun branch,
            Lamphun 2, was established.</p>
        </div>
      </article>

      <article class="t-slot" data-decade="2010s" data-year="2015">
        <div class="t-card">
          <span class="t-year">2015</span>
          <h3 class="t-headline">Two new factories open</h3>
          <p class="t-body">Lamphun 2 began operations in semiconductors and
            PCBA. In September, the Cambodia plant came online — initially
            assembling RFID access control readers and quartz crystals.</p>
        </div>
      </article>

      <article class="t-slot" data-decade="2010s" data-year="2017">
        <div class="t-card">
          <span class="t-year">2017</span>
          <h3 class="t-headline">Thailand capacity expansion</h3>
          <p class="t-body">Lamphun 2 fitted out a second floor, doubling its
            manufacturing capacity. Ayutthaya added a three-story, 2,600&nbsp;m²
            warehouse.</p>
        </div>
      </article>

      <article class="t-slot" data-decade="2010s" data-year="2017">
        <div class="t-card">
          <span class="t-year">2017</span>
          <h3 class="t-headline">Power Master Semiconductor, in Korea</h3>
          <p class="t-body">Power Master Semiconductor Co., Ltd. (PMS) was
            established in Korea to manufacture IC power management devices
            &mdash; extending Hana&rsquo;s manufacturing footprint into Korea.</p>
        </div>
      </article>

      <article class="t-slot" data-decade="2010s" data-year="2018">
        <div class="t-card">
          <span class="t-year">2018</span>
          <h3 class="t-headline">Lamphun 2 grows; Ohio renamed</h3>
          <p class="t-body">Lamphun 2 added 6,000 m² of production. The Ohio
            subsidiary became Hana Technologies, Inc., reflecting a broader
            scope across LCoS and RFID device manufacturing.</p>
        </div>
      </article>

      <article class="t-slot" data-decade="2010s" data-year="2019">
        <div class="t-card">
          <span class="t-year">2019</span>
          <h3 class="t-headline">A cleaner subsidiary structure</h3>
          <p class="t-body">Three holding subsidiaries — Hana Technologies
            Group, Hana Technologies Investments, and Hana Semiconductor
            Holdings — were dissolved. No gain or loss recognized.</p>
        </div>
      </article>

      <div class="decade-marker" aria-hidden="true"><span>2020s</span></div>

      <article class="t-slot" data-decade="2020s" data-year="2020">
        <div class="t-card">
          <span class="t-year">2020</span>
          <h3 class="t-headline">Ayutthaya keeps growing</h3>
          <p class="t-body">Ayutthaya added 6,650 m² of office and production
            space to support continuing growth in demand.</p>
        </div>
      </article>

      <article class="t-slot" data-decade="2020s" data-year="2021">
        <div class="t-card">
          <span class="t-year">2021</span>
          <h3 class="t-headline">Into the RFID inlay OEM business</h3>
          <p class="t-body">Hana Technologies, Inc. entered the RFID inlay OEM
            business — a deliberate move into higher-volume RFID
            manufacturing.</p>
        </div>
      </article>

      <article class="t-slot" data-decade="2020s" data-year="2023">
        <div class="t-card">
          <span class="t-year">2023</span>
          <h3 class="t-headline">Capital raise; a new home in Ohio</h3>
          <p class="t-body">Completed a private placement of 80.48 million
            shares, raising THB 4.58 billion gross. Hana Technologies, Inc.
            relocated to Solon, Ohio, tripling manufacturing floor space.</p>
        </div>
      </article>

      <article class="t-slot" data-decade="2020s" data-year="2024">
        <div class="t-card">
          <span class="t-year">2024</span>
          <h3 class="t-headline">Investment in FT1 Corporation</h3>
          <p class="t-body">Entered an agreement with NewVersal Co., Ltd. (PTT
            Public Co., Ltd.) to invest in FT1 Corporation, holding 49% after a
            further THB 744.8 million investment. Ayutthaya purchased adjacent
            land for THB 86 million.</p>
        </div>
      </article>

      <article class="t-slot" data-decade="2020s" data-year="2025">
        <div class="t-card">
          <span class="t-year">2025</span>
          <h3 class="t-headline">Cambodia land sale</h3>
          <p class="t-body">In February 2025, the company sold land held for
            dormitory development in Cambodia for USD 1.3 million.</p>
        </div>
      </article>

    </div>
  </div>

  <button class="nav-btn nav-next" aria-label="Next event">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <polyline points="9 18 15 12 9 6"></polyline>
    </svg>
  </button>
</section>

</div>
<!-- ── /heritage-flow ── -->

<!-- ── Progress bar ── -->
<div class="progress">
  <div class="progress-bar"><div class="progress-fill"></div></div>
  <div class="progress-label">
    <span class="current">1978</span>
    <span class="count"><span id="current-count">1</span> / <span id="total-count">30</span></span>
  </div>
</div>

@section Scripts {
    <script src="~/js/about-heritage.js"></script>
}
