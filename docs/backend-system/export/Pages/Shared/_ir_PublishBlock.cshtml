@*
   _ir_PublishBlock.cshtml — the "Publish now / at a set time" chooser shared
   by the news and report forms. Enhanced by ir-admin.js; the hidden input
   carries the chosen mode on POST. For a live record the caller shows its own
   note instead of this chooser. ViewData["mode"] = "now" | "later".
*@
@{
    var mode = ViewData["mode"] as string ?? "now";
    var later = mode == "later";
}
<input type="hidden" id="ir-publish-mode" name="PublishMode" value="@mode" />
<div class="ir-choice">
    <div class="ir-choice-opt @(later ? "" : "is-on")" data-pub-opt="now">
        <span class="ir-choice-dot"></span>
        <span><span class="t">Publish now</span><span class="d">Appears on the website within a few seconds of pressing Publish.</span></span>
    </div>
    <div class="ir-choice-opt @(later ? "is-on" : "")" data-pub-opt="later">
        <span class="ir-choice-dot"></span>
        <span><span class="t">Publish at a set time</span><span class="d">Stays hidden until the moment you choose, then appears on its own.</span></span>
    </div>
</div>
<div class="ir-golive-field @(later ? "" : "is-hidden")" id="ir-golive-field">
    <label style="display:block;font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:0.1em;color:var(--ink-3);margin-bottom:6px">Go live at <span class="ir-req">*</span></label>
    <input class="ir-input" type="datetime-local" name="GoLiveAt" value="2026-08-12T08:00" />
    <div class="ir-help">Thailand time (UTC+7).</div>
</div>
<div class="ir-note ir-note--warn" style="margin-top:18px"><strong>This is the one that matters for SET filings.</strong> Set the time and the item stays completely invisible — the files cannot be reached by anyone who guesses the address — until the moment it is disclosed to the Exchange.</div>
