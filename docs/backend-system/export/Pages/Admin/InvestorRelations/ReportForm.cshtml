@page
@model HanaSite.Pages.Admin.InvestorRelations.ReportFormModel
@using HanaSite.Models.Ir
@{
    Layout = null;
    var ed = Model.Existing;
    var barCss = ed == null ? "" : "ir-editbar--" + ed.Status.Css();
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>@(Model.Editing ? "Edit" : "New") report — Hana Admin</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Geist:wght@@400;600;700&amp;family=Inter:wght@@400;500;600;800&amp;family=IBM+Plex+Mono:wght@@500&amp;display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/_tokens.css" />
    <link rel="stylesheet" href="~/css/ir-admin.css" />
</head>
<body class="ir-body">
    <partial name="_IrAdminHeader" model="Jirapa K. · Corporate Affairs" />
    <partial name="_ir_TabBar" model="@("report-form")" />

    <main class="ir-wrap">
        <div class="ir-form-wrap">
            <div class="ir-form-head">
                <h2>@(Model.Editing ? "Edit report" : "New report")</h2>
                <div class="sub">@(Model.Editing ? (Model.IsLive ? "Changes save straight to the live page" : "Not yet public") : "Draft — not visible to the public")</div>
            </div>

            @if (ed != null)
            {
                <div class="ir-editbar @barCss">
                    <div class="who">
                        <div class="t">@ed.Title</div>
                        <div class="a">@(Model.IsLive ? "Published by Penpimol K. · last edited 2 Jun 2026" : "Draft · created 18 Jul 2026 by Jirapa K.")</div>
                    </div>
                    <div class="right">
                        <partial name="_ir_StatusPill" model="ed.Status" />
                        <button type="button" class="ir-btn">View on website ↗</button>
                    </div>
                </div>
            }

            <form method="post" enctype="multipart/form-data">
                <input type="hidden" asp-for="Id" />

                <div class="ir-card">
                    <div class="ir-card-head"><h3>1 · Report details</h3></div>
                    <div class="ir-card-body">
                        <div class="ir-formgrid">
                            <div class="ir-field">
                                <label asp-for="Input.Type">Report type <span class="ir-req">*</span></label>
                                <select asp-for="Input.Type" class="ir-select"><option>Annual Report</option><option>56-1 One Report</option></select>
                            </div>
                            <div class="ir-field">
                                <label asp-for="Input.Year">Year <span class="ir-req">*</span></label>
                                <select asp-for="Input.Year" class="ir-select"><option>2026</option><option>2025</option><option>2024</option><option>2023</option></select>
                                <div class="ir-help">Decides where the report sits in the grid — newest first, always.</div>
                            </div>
                            <div class="ir-field ir-col-full">
                                <label asp-for="Input.Title">Title <span class="ir-auto" style="color:var(--ink-3);background:var(--surface);border:1px solid var(--line)">English</span> <span class="ir-req">*</span></label>
                                <input asp-for="Input.Title" class="ir-input" placeholder="e.g. Annual Report 2025" />
                                <span class="ir-val" asp-validation-for="Input.Title"></span>
                            </div>
                            <div class="ir-field ir-col-full">
                                <label asp-for="Input.TitleTh">Title <span class="ir-auto" style="color:var(--ink-3);background:var(--surface);border:1px solid var(--line)">ไทย</span> <span class="ir-req">*</span></label>
                                <input asp-for="Input.TitleTh" class="ir-input" placeholder="เช่น รายงานประจำปี 2568" />
                                <span class="ir-val" asp-validation-for="Input.TitleTh"></span>
                            </div>
                            <div class="ir-field ir-col-full">
                                <label asp-for="Input.Description">Short description <span class="ir-auto" style="color:var(--ink-3);background:var(--surface);border:1px solid var(--line)">English</span> <span class="ir-opt">(optional)</span></label>
                                <textarea asp-for="Input.Description" class="ir-textarea" placeholder="One line shown under the title on the report card."></textarea>
                            </div>
                            <div class="ir-field ir-col-full">
                                <label asp-for="Input.DescriptionTh">Short description <span class="ir-auto" style="color:var(--ink-3);background:var(--surface);border:1px solid var(--line)">ไทย</span> <span class="ir-opt">(optional)</span></label>
                                <textarea asp-for="Input.DescriptionTh" class="ir-textarea" placeholder="ประโยคเดียวที่แสดงใต้หัวข้อบนการ์ดรายงาน"></textarea>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="ir-card">
                    <div class="ir-card-head"><h3>2 · Cover thumbnail</h3></div>
                    <div class="ir-card-body">
                        <div class="ir-cover-grid">
                            <div>
                                <label class="ir-drop">
                                    <div class="t">Choose an image</div>
                                    <div class="d">or drag it here<br />JPG or PNG · portrait · at least 600px wide</div>
                                    <input type="file" name="Cover" accept="image/*" style="display:none" />
                                </label>
                                <div class="ir-help" style="margin-top:8px">The image is resized for you — a large scan won't slow the page down.</div>
                            </div>
                            <div class="ir-preview-pair">
                                <div class="ir-preview">
                                    <div class="cap">If you upload one</div>
                                    <div class="ir-cover-lg ir-cover-lg--img">
                                        <div style="font-size:7.5px;letter-spacing:0.12em;text-transform:uppercase;opacity:0.75">Annual Report</div>
                                        <div style="font-size:28px;font-weight:700;letter-spacing:-0.03em;line-height:1.05">2025</div>
                                        <div style="font-size:8px;opacity:0.7;margin-top:6px;letter-spacing:0.06em">Hana Microelectronics</div>
                                    </div>
                                    <div class="note">Your image, shown on the report card.</div>
                                </div>
                                <div class="ir-preview">
                                    <div class="cap">If you leave it empty</div>
                                    <div class="ir-cover-lg ir-cover-lg--auto">
                                        <div style="font-size:7.5px;letter-spacing:0.12em;text-transform:uppercase;margin-bottom:6px">Automatic</div>
                                        <div style="font-size:13px;font-weight:600;color:var(--ink-2)">Page 1 of the PDF</div>
                                    </div>
                                    <div class="note">The first page of the report is used instead.</div>
                                </div>
                            </div>
                        </div>
                        <div class="ir-note" style="margin-top:18px"><strong>A cover is never missing.</strong> If no image is uploaded, the system takes page one of the first PDF attached below. Uploading an image simply overrides that.</div>
                    </div>
                </div>

                <div class="ir-card">
                    <div class="ir-card-head"><h3>3 · Attachments</h3></div>
                    <div class="ir-card-body">
                        <div class="ir-note" style="margin-bottom:16px"><strong>One record, as many files as it needs.</strong> English, Thai, the financial statements — all here rather than a separate entry for each. They appear as separate download buttons on the page.</div>
                        <partial name="_ir_AttachmentEditor" model="Model.Input.Attachments" view-data='new Microsoft.AspNetCore.Mvc.ViewFeatures.ViewDataDictionary(ViewData) { { "field", "Input.Attachments" } }' />
                    </div>
                </div>

                <div class="ir-card">
                    <div class="ir-card-head"><h3>4 · Publishing</h3></div>
                    <div class="ir-card-body">
                        @if (Model.IsLive)
                        {
                            <div class="ir-note ir-note--warn"><strong>This report is already on the website.</strong> Pressing <em>Save changes</em> updates the live page straight away. Adding a file appears as a new download button as soon as you save.</div>
                        }
                        else
                        {
                            <partial name="_ir_PublishBlock" view-data='new Microsoft.AspNetCore.Mvc.ViewFeatures.ViewDataDictionary(ViewData) { { "mode", Model.Input.PublishMode } }' />
                        }
                        <div style="margin-top:18px">
                            <label style="display:block;font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:0.1em;color:var(--ink-3);margin-bottom:6px">Page address <span class="ir-auto">Automatic</span></label>
                            <input class="ir-input ir-input--auto" value="hanagroup.com/investor-relations/annual-report/" readonly />
                        </div>
                    </div>
                    <div class="ir-card-foot">
                        @if (Model.IsLive)
                        {
                            <button type="submit" class="ir-btn ir-btn--primary ir-btn--lg">Save changes</button>
                            <button type="submit" class="ir-btn ir-btn--lg" formnovalidate>Preview</button>
                            <button type="submit" class="ir-btn ir-btn--lg" formnovalidate>Unpublish</button>
                            <span class="hint">Every change is recorded against your name</span>
                        }
                        else
                        {
                            <button type="submit" class="ir-btn ir-btn--primary ir-btn--lg">Publish to website</button>
                            <button type="submit" class="ir-btn ir-btn--lg" formnovalidate>Save as draft</button>
                            <button type="submit" class="ir-btn ir-btn--lg" formnovalidate>Preview</button>
                            <span class="hint">Draft saved automatically at 14:48</span>
                        }
                    </div>
                </div>

                <div style="margin:0 0 40px"><a class="ir-btn" asp-page="/Admin/InvestorRelations/Index" asp-route-tab="reports">← Back to reports</a></div>
            </form>
        </div>
    </main>

    <script src="~/js/ir-admin.js" asp-append-version="true"></script>
</body>
</html>
